#!/usr/bin/env bash
# crew — Agent team launcher, workspace manager & package registry
#
# Launch:
#   crew [workspace]                     Launch in Cursor
#   crew [workspace] -a                  Launch agents only (tmux)
#
# Workspace & project management:
#   crew workspace [create|list|remove]
#   crew project [add|list|remove]
#
# Registry:
#   crew agents [list|install|remove|update|run]
#   crew skills [list|install|remove|update]
#   crew run [agent]                     Shortcut for agents run
#   crew update                          Update all agents+skills+profile
#
# Profile:
#   crew profile [install|show|update|remove]
#
# Notifications:
#   crew notify [setup|status|test|remove]
#
#   crew kill
#   crew help

set -euo pipefail

# ─────────────────────────────────────────────
# CONSTANTS
# ─────────────────────────────────────────────
CONFIG_DIR="${HOME}/.crew"
WORKSPACES_DIR="${CONFIG_DIR}/workspaces"

REGISTRY_REPO="FurlanLuka/homebrew-tap"
REGISTRY_BRANCH="main"
REGISTRY_BASE="registry"

mkdir -p "$WORKSPACES_DIR"

# ─────────────────────────────────────────────
# HELPERS — color & output
# ─────────────────────────────────────────────
red()    { printf "\033[31m%s\033[0m\n" "$1"; }
green()  { printf "\033[32m%s\033[0m\n" "$1"; }
blue()   { printf "\033[34m%s\033[0m\n" "$1"; }
bold()   { printf "\033[1m%s\033[0m\n" "$1"; }
dim()    { printf "\033[2m%s\033[0m\n" "$1"; }

die() { red "Error: $1"; exit 1; }

# ─────────────────────────────────────────────
# HELPERS — parsing & hashing
# ─────────────────────────────────────────────
parse_frontmatter() {
  local key="$1"
  sed -n '/^---$/,/^---$/p' | grep "^${key}:" | sed "s/^${key}:[[:space:]]*//"
}

content_hash() {
  shasum -a 256 | cut -d' ' -f1
}

# ─────────────────────────────────────────────
# HELPERS — pickers (gum + fallback)
# ─────────────────────────────────────────────
has_gum() { command -v gum &>/dev/null; }

pick_one() {
  local header="$1"; shift
  local opts=("$@")
  [[ ${#opts[@]} -eq 0 ]] && return 1

  if has_gum; then
    gum choose --header "$header" "${opts[@]}"
  else
    echo "$header" >&2
    local i=1
    for opt in "${opts[@]}"; do
      printf "  %d) %s\n" "$i" "$opt" >&2
      ((i++))
    done
    printf "Enter number: " >&2
    local choice
    read -r choice
    [[ "$choice" =~ ^[0-9]+$ ]] || return 1
    ((choice >= 1 && choice <= ${#opts[@]})) || return 1
    echo "${opts[$((choice-1))]}"
  fi
}

pick_many() {
  local header="$1"; shift
  local opts=("$@")
  [[ ${#opts[@]} -eq 0 ]] && return 1

  if has_gum; then
    gum choose --no-limit --header "$header" "${opts[@]}"
  else
    echo "$header" >&2
    local i=1
    for opt in "${opts[@]}"; do
      printf "  %d) %s\n" "$i" "$opt" >&2
      ((i++))
    done
    printf "Enter numbers (space-separated): " >&2
    local choices
    read -r choices
    for c in $choices; do
      [[ "$c" =~ ^[0-9]+$ ]] || continue
      ((c >= 1 && c <= ${#opts[@]})) || continue
      echo "${opts[$((c-1))]}"
    done
  fi
}

# ─────────────────────────────────────────────
# HELPERS — GitHub
# ─────────────────────────────────────────────
gh_api() {
  local endpoint="$1"
  local url="https://api.github.com/repos/${REGISTRY_REPO}/contents/${endpoint}?ref=${REGISTRY_BRANCH}"
  curl -sf -H "Accept: application/vnd.github.v3+json" "$url"
}

gh_raw() {
  local path="$1"
  local url="https://raw.githubusercontent.com/${REGISTRY_REPO}/${REGISTRY_BRANCH}/${path}"
  curl -sf "$url"
}

# ─────────────────────────────────────────────
# HELPERS — workspace
# ─────────────────────────────────────────────
workspace_file() { echo "$WORKSPACES_DIR/$1.json"; }

workspace_exists() {
  [[ -f "$(workspace_file "$1")" ]]
}

pick_workspace() {
  local ws="${1:-}"
  if [[ -n "$ws" ]]; then
    workspace_exists "$ws" || die "Workspace '$ws' not found."
    echo "$ws"
    return
  fi

  local workspaces=()
  for f in "$WORKSPACES_DIR"/*.json; do
    [[ -f "$f" ]] || continue
    workspaces+=("$(basename "$f" .json)")
  done

  [[ ${#workspaces[@]} -eq 0 ]] && die "No workspaces. Create one with: crew workspace create <name>"

  pick_one "Select workspace:" "${workspaces[@]}" || exit 1
}

read_projects() {
  local ws="$1"
  python3 -c "
import json, sys
with open('$(workspace_file "$ws")') as f:
    data = json.load(f)
if not data['projects']:
    sys.exit(1)
for p in data['projects']:
    print(f\"{p['name']}|{p['path']}|{p['role']}\")
" 2>/dev/null || die "No projects in workspace '$ws'. Add some with: crew project add $ws"
}

attach_session() {
  local session="$1"
  if [[ "${TERM_PROGRAM:-}" == "iTerm.app" ]]; then
    tmux -CC attach -t "$session"
  else
    tmux attach -t "$session"
  fi
}

cleanup_workspace() {
  local ws="$1"
  local session="crew-$ws"

  if tmux has-session -t "$session" 2>/dev/null; then
    tmux kill-session -t "$session"
    echo "Killed agent session: $session"
  fi

  rm -f "${CONFIG_DIR}/prompt-${ws}.md" 2>/dev/null

  local ws_file="${CONFIG_DIR}/${ws}.code-workspace"
  if [[ -f "$ws_file" ]]; then
    local process_name=""
    if command -v cursor &>/dev/null; then
      process_name="Cursor"
    elif command -v code &>/dev/null; then
      process_name="Code"
    fi
    if [[ -n "$process_name" ]]; then
      osascript -e "
        tell application \"System Events\"
          if exists process \"$process_name\" then
            tell process \"$process_name\"
              repeat with w in (every window)
                if name of w contains \"$ws\" then
                  click button 1 of w
                end if
              end repeat
            end tell
          end if
        end tell
      " 2>/dev/null || true
    fi
    rm -f "$ws_file"
  fi

  green "Workspace '$ws' torn down."
}

# ─────────────────────────────────────────────
# CONFIG — resolve CLAUDE_CONFIG_DIR
# ─────────────────────────────────────────────
resolve_config() {
  CLAUDE_CONFIG_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
  export CLAUDE_CONFIG_DIR
}

# ─────────────────────────────────────────────
# WORKSPACE COMMANDS
# ─────────────────────────────────────────────
cmd_workspace_create() {
  local name="${1:-}"
  [[ -z "$name" ]] && die "Usage: crew workspace create <name>"
  workspace_exists "$name" && die "Workspace '$name' already exists."

  python3 -c "
import json
data = {'name': '$name', 'projects': []}
with open('$(workspace_file "$name")', 'w') as f:
    json.dump(data, f, indent=2)
"
  green "Workspace '$name' created."
  echo "   Add projects with: crew project add $name"
}

cmd_workspace_list() {
  bold "Workspaces:"
  echo ""
  local found=0
  for f in "$WORKSPACES_DIR"/*.json; do
    [[ -f "$f" ]] || continue
    found=1
    local name
    name=$(basename "$f" .json)
    local count
    count=$(python3 -c "import json; print(len(json.load(open('$f'))['projects']))" 2>/dev/null || echo 0)
    echo "  $name ($count projects)"
  done
  if [[ $found -eq 0 ]]; then
    dim "  No workspaces yet. Create one with: crew workspace create <name>"
  fi
}

cmd_workspace_remove() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    local workspaces=()
    for f in "$WORKSPACES_DIR"/*.json; do
      [[ -f "$f" ]] || continue
      workspaces+=("$(basename "$f" .json)")
    done
    [[ ${#workspaces[@]} -eq 0 ]] && die "No workspaces to remove."
    name=$(pick_one "Select workspace to remove:" "${workspaces[@]}") || return 0
    [[ -z "$name" ]] && return 0
  fi
  workspace_exists "$name" || die "Workspace '$name' not found."

  rm "$(workspace_file "$name")"
  green "Workspace '$name' removed."
}

dispatch_workspace() {
  local sub="${1:-}"
  if [[ -z "$sub" ]]; then
    sub=$(pick_one "Workspace action:" "create" "list" "remove") || exit 1
  fi
  case "$sub" in
    create) cmd_workspace_create "${2:-}" ;;
    list)   cmd_workspace_list ;;
    remove) cmd_workspace_remove "${2:-}" ;;
    *)      die "Unknown: crew workspace $sub. Try: create, list, remove" ;;
  esac
}

# ─────────────────────────────────────────────
# PROJECT COMMANDS
# ─────────────────────────────────────────────
cmd_project_add() {
  local ws="${1:-}"
  if [[ -z "$ws" ]]; then
    ws=$(pick_workspace "")
  fi
  workspace_exists "$ws" || die "Workspace '$ws' not found."

  printf "Project name: "
  read -er proj_name
  [[ -z "$proj_name" ]] && die "Name cannot be empty."

  printf "Project path: "
  read -er proj_path
  proj_path="${proj_path/#\~/$HOME}"
  [[ -d "$proj_path" ]] || die "Directory not found: $proj_path"
  proj_path="$(cd "$proj_path" && pwd)"

  printf "Agent role description (e.g. 'owns the backend API'): "
  read -er proj_role
  [[ -z "$proj_role" ]] && proj_role="works on $proj_name"

  python3 -c "
import json
with open('$(workspace_file "$ws")', 'r') as f:
    data = json.load(f)
proj = {
    'name': $(python3 -c "import json; print(json.dumps('$proj_name'))"),
    'path': $(python3 -c "import json; print(json.dumps('$proj_path'))"),
    'role': $(python3 -c "import json; print(json.dumps('$proj_role'))")
}
data['projects'].append(proj)
with open('$(workspace_file "$ws")', 'w') as f:
    json.dump(data, f, indent=2)
"
  green "Added '$proj_name' to workspace '$ws'."
}

cmd_project_list() {
  local ws="${1:-}"
  if [[ -z "$ws" ]]; then
    ws=$(pick_workspace "")
  fi
  workspace_exists "$ws" || die "Workspace '$ws' not found."

  bold "Projects in '$ws':"
  echo ""
  python3 -c "
import json
with open('$(workspace_file "$ws")') as f:
    data = json.load(f)
if not data['projects']:
    print('  No projects yet. Add one with: crew project add $ws')
for p in data['projects']:
    print(f\"  {p['name']}\")
    print(f\"    path:  {p['path']}\")
    print(f\"    role:  {p['role']}\")
    print()
"
}

cmd_project_remove() {
  local ws="${1:-}"
  local proj="${2:-}"
  [[ -z "$ws" || -z "$proj" ]] && die "Usage: crew project remove <workspace> <project>"
  workspace_exists "$ws" || die "Workspace '$ws' not found."

  python3 -c "
import json, sys
with open('$(workspace_file "$ws")', 'r') as f:
    data = json.load(f)
before = len(data['projects'])
data['projects'] = [p for p in data['projects'] if p['name'] != '$proj']
if len(data['projects']) == before:
    sys.exit(1)
with open('$(workspace_file "$ws")', 'w') as f:
    json.dump(data, f, indent=2)
" || die "Project '$proj' not found in workspace '$ws'."
  green "Removed '$proj' from workspace '$ws'."
}

dispatch_project() {
  local sub="${1:-}"
  if [[ -z "$sub" ]]; then
    sub=$(pick_one "Project action:" "add" "list" "remove") || exit 1
  fi
  case "$sub" in
    add)    cmd_project_add "${2:-}" ;;
    list)   cmd_project_list "${2:-}" ;;
    remove) cmd_project_remove "${2:-}" "${3:-}" ;;
    *)      die "Unknown: crew project $sub. Try: add, list, remove" ;;
  esac
}

# ─────────────────────────────────────────────
# REGISTRY FETCHERS
# ─────────────────────────────────────────────
fetch_registry_agent_names() {
  local response
  response=$(gh_api "${REGISTRY_BASE}/agents") || die "Failed to fetch agent registry."
  echo "$response" | python3 -c "
import json, sys
items = json.load(sys.stdin)
for item in items:
    name = item['name']
    if name.endswith('.md'):
        print(name[:-3])
" 2>/dev/null
}

fetch_registry_skill_names() {
  local response
  response=$(gh_api "${REGISTRY_BASE}/skills") || die "Failed to fetch skill registry."
  echo "$response" | python3 -c "
import json, sys
items = json.load(sys.stdin)
for item in items:
    if item['type'] == 'dir':
        print(item['name'])
" 2>/dev/null
}

get_installed_agent_names() {
  local dir="${CLAUDE_CONFIG_DIR}/agents"
  if [[ -d "$dir" ]]; then
    for f in "$dir"/*.md; do
      [[ -f "$f" ]] || continue
      basename "$f" .md
    done
  fi
}

get_installed_skill_names() {
  local dir="${CLAUDE_CONFIG_DIR}/skills"
  if [[ -d "$dir" ]]; then
    for d in "$dir"/*/; do
      [[ -d "$d" ]] || continue
      [[ -f "${d}SKILL.md" ]] || continue
      basename "$d"
    done
  fi
}

# ─────────────────────────────────────────────
# REGISTRY: AGENTS
# ─────────────────────────────────────────────
cmd_agents_list() {
  bold "Installed agents:"
  echo ""

  local found=0
  local dir="${CLAUDE_CONFIG_DIR}/agents"
  if [[ -d "$dir" ]]; then
    for f in "$dir"/*.md; do
      [[ -f "$f" ]] || continue
      found=1
      local name
      name=$(basename "$f" .md)
      local desc
      desc=$(parse_frontmatter "description" < "$f")
      if [[ -n "$desc" ]]; then
        printf "  %-24s %s\n" "$name" "$desc"
      else
        echo "  $name"
      fi
    done
  fi

  if [[ $found -eq 0 ]]; then
    dim "  No agents installed."
  fi
}

_install_single_agent() {
  local name="$1"
  local project="${2:-false}"

  local target_dir
  if [[ "$project" == true ]]; then
    target_dir=".claude/agents"
  else
    target_dir="${CLAUDE_CONFIG_DIR}/agents"
  fi

  mkdir -p "$target_dir"

  local content
  content=$(gh_raw "${REGISTRY_BASE}/agents/${name}.md") || die "Agent '${name}' not found in registry."

  echo "$content" > "${target_dir}/${name}.md"

  if [[ "$project" == true ]]; then
    green "Installed agent '${name}' to project (.claude/agents/${name}.md)"
  else
    green "Installed agent '${name}' globally (${target_dir}/${name}.md)"
  fi
}

cmd_agents_install() {
  local name="" project=false
  for arg in "$@"; do
    if [[ "$arg" == "-p" ]]; then
      project=true
    elif [[ -z "$name" ]]; then
      name="$arg"
    fi
  done

  if [[ -n "$name" ]]; then
    _install_single_agent "$name" "$project"
    return
  fi

  local names
  names=$(fetch_registry_agent_names) || return 1
  [[ -z "$names" ]] && { dim "No agents in registry."; return; }

  local opts=()
  while IFS= read -r n; do
    opts+=("$n")
  done <<< "$names"

  local selected
  selected=$(pick_many "Select agents to install:" "${opts[@]}") || return 0
  [[ -z "$selected" ]] && return 0

  while IFS= read -r n; do
    _install_single_agent "$n" "$project"
  done <<< "$selected"
}

cmd_agents_remove() {
  local name="${1:-}"

  if [[ -z "$name" ]]; then
    local names
    names=$(get_installed_agent_names)
    [[ -z "$names" ]] && die "No agents installed."

    local opts=()
    while IFS= read -r n; do
      opts+=("$n")
    done <<< "$names"

    name=$(pick_one "Select agent to remove:" "${opts[@]}") || return 0
    [[ -z "$name" ]] && return 0
  fi

  local file="${CLAUDE_CONFIG_DIR}/agents/${name}.md"
  [[ -f "$file" ]] || die "Agent '${name}' not found."
  rm "$file"
  green "Removed agent '${name}'."
}

cmd_agents_update() {
  local name="${1:-}"

  if [[ -n "$name" ]]; then
    local file="${CLAUDE_CONFIG_DIR}/agents/${name}.md"
    [[ -f "$file" ]] || die "Agent '${name}' not installed."

    local content
    content=$(gh_raw "${REGISTRY_BASE}/agents/${name}.md") || die "Agent '${name}' not found in registry."
    local remote_hash
    remote_hash=$(echo "$content" | content_hash)
    local local_hash
    local_hash=$(echo "$(cat "$file")" | content_hash)

    if [[ "$remote_hash" == "$local_hash" ]]; then
      dim "Agent '${name}' already up to date."
    else
      echo "$content" > "$file"
      green "Updated agent '${name}'."
    fi
    return
  fi

  local found=0
  local dir="${CLAUDE_CONFIG_DIR}/agents"
  if [[ -d "$dir" ]]; then
    for f in "$dir"/*.md; do
      [[ -f "$f" ]] || continue
      found=1
      local n
      n=$(basename "$f" .md)
      local content
      content=$(gh_raw "${REGISTRY_BASE}/agents/${n}.md") || continue
      local remote_hash
      remote_hash=$(echo "$content" | content_hash)
      local local_hash
      local_hash=$(echo "$(cat "$f")" | content_hash)
      if [[ "$remote_hash" == "$local_hash" ]]; then
        dim "Agent '${n}' already up to date."
      else
        echo "$content" > "$f"
        green "Updated agent '${n}'."
      fi
    done
  fi

  if [[ $found -eq 0 ]]; then
    dim "No agents to update."
  fi
}

cmd_agents_run() {
  local name="${1:-}"

  if [[ -z "$name" ]]; then
    local names
    names=$(get_installed_agent_names)
    [[ -z "$names" ]] && die "No agents installed. Run: crew agents install"

    local opts=()
    while IFS= read -r n; do
      opts+=("$n")
    done <<< "$names"

    name=$(pick_one "Select agent to run:" "${opts[@]}") || return 0
    [[ -z "$name" ]] && return 0
  fi

  [[ -f "${CLAUDE_CONFIG_DIR}/agents/${name}.md" ]] || die "Agent '${name}' not installed. Run: crew agents install ${name}"

  blue "Starting agent: ${name}"
  dim "  Config: ${CLAUDE_CONFIG_DIR}"
  echo ""

  exec claude --agent "$name"
}

dispatch_agents() {
  local sub="${1:-}"
  if [[ -z "$sub" ]]; then
    sub=$(pick_one "Agents action:" "list" "install" "remove" "update" "run") || exit 1
  fi
  case "$sub" in
    list)      cmd_agents_list ;;
    install)   shift 2>/dev/null || true; cmd_agents_install "$@" ;;
    remove)    cmd_agents_remove "${2:-}" ;;
    update)    cmd_agents_update "${2:-}" ;;
    run)       cmd_agents_run "${2:-}" ;;
    *)         die "Unknown: crew agents $sub. Try: list, install, remove, update, run" ;;
  esac
}

# ─────────────────────────────────────────────
# REGISTRY: SKILLS
# ─────────────────────────────────────────────
cmd_skills_list() {
  bold "Installed skills:"
  echo ""

  local found=0
  local dir="${CLAUDE_CONFIG_DIR}/skills"
  if [[ -d "$dir" ]]; then
    for d in "$dir"/*/; do
      [[ -d "$d" ]] || continue
      [[ -f "${d}SKILL.md" ]] || continue
      found=1
      local name
      name=$(basename "$d")
      local desc
      desc=$(parse_frontmatter "description" < "${d}SKILL.md")
      if [[ -n "$desc" ]]; then
        printf "  %-24s %s\n" "$name" "$desc"
      else
        echo "  $name"
      fi
    done
  fi

  if [[ $found -eq 0 ]]; then
    dim "  No skills installed."
  fi
}

_install_single_skill() {
  local name="$1"
  local project="${2:-false}"

  local target_dir
  if [[ "$project" == true ]]; then
    target_dir=".claude/skills/${name}"
  else
    target_dir="${CLAUDE_CONFIG_DIR}/skills/${name}"
  fi

  mkdir -p "$target_dir"

  local response
  response=$(gh_api "${REGISTRY_BASE}/skills/${name}") || die "Skill '${name}' not found in registry."

  local files
  files=$(echo "$response" | python3 -c "
import json, sys

def list_files(items, prefix=''):
    for item in items:
        path = prefix + item['name'] if prefix else item['name']
        if item['type'] == 'file':
            print(path)

items = json.load(sys.stdin)
list_files(items)
" 2>/dev/null) || die "Failed to parse skill contents."

  while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    local content
    content=$(gh_raw "${REGISTRY_BASE}/skills/${name}/${file}") || { red "Failed to download: ${file}"; continue; }

    local file_dir
    file_dir=$(dirname "$file")
    if [[ "$file_dir" != "." ]]; then
      mkdir -p "${target_dir}/${file_dir}"
    fi

    echo "$content" > "${target_dir}/${file}"
  done <<< "$files"

  # Handle subdirectories (one level deep)
  local dirs
  dirs=$(echo "$response" | python3 -c "
import json, sys
items = json.load(sys.stdin)
for item in items:
    if item['type'] == 'dir':
        print(item['name'])
" 2>/dev/null) || true

  while IFS= read -r subdir; do
    [[ -z "$subdir" ]] && continue
    mkdir -p "${target_dir}/${subdir}"

    local sub_response
    sub_response=$(gh_api "${REGISTRY_BASE}/skills/${name}/${subdir}") || continue

    local sub_files
    sub_files=$(echo "$sub_response" | python3 -c "
import json, sys
items = json.load(sys.stdin)
for item in items:
    if item['type'] == 'file':
        print(item['name'])
" 2>/dev/null) || continue

    while IFS= read -r sf; do
      [[ -z "$sf" ]] && continue
      local sc
      sc=$(gh_raw "${REGISTRY_BASE}/skills/${name}/${subdir}/${sf}") || continue
      echo "$sc" > "${target_dir}/${subdir}/${sf}"
    done <<< "$sub_files"
  done <<< "$dirs"

  if [[ "$project" == true ]]; then
    green "Installed skill '${name}' to project (.claude/skills/${name}/)"
  else
    green "Installed skill '${name}' globally (${target_dir}/)"
  fi
}

cmd_skills_install() {
  local name="" project=false
  for arg in "$@"; do
    if [[ "$arg" == "-p" ]]; then
      project=true
    elif [[ -z "$name" ]]; then
      name="$arg"
    fi
  done

  if [[ -n "$name" ]]; then
    _install_single_skill "$name" "$project"
    return
  fi

  local names
  names=$(fetch_registry_skill_names) || return 1
  [[ -z "$names" ]] && { dim "No skills in registry."; return; }

  local opts=()
  while IFS= read -r n; do
    opts+=("$n")
  done <<< "$names"

  local selected
  selected=$(pick_many "Select skills to install:" "${opts[@]}") || return 0
  [[ -z "$selected" ]] && return 0

  while IFS= read -r n; do
    _install_single_skill "$n" "$project"
  done <<< "$selected"
}

cmd_skills_remove() {
  local name="${1:-}"

  if [[ -z "$name" ]]; then
    local names
    names=$(get_installed_skill_names)
    [[ -z "$names" ]] && die "No skills installed."

    local opts=()
    while IFS= read -r n; do
      opts+=("$n")
    done <<< "$names"

    name=$(pick_one "Select skill to remove:" "${opts[@]}") || return 0
    [[ -z "$name" ]] && return 0
  fi

  local dir="${CLAUDE_CONFIG_DIR}/skills/${name}"
  [[ -d "$dir" ]] || die "Skill '${name}' not found."
  rm -rf "$dir"
  green "Removed skill '${name}'."
}

cmd_skills_update() {
  local name="${1:-}"

  if [[ -n "$name" ]]; then
    local dir="${CLAUDE_CONFIG_DIR}/skills/${name}"
    [[ -d "$dir" ]] || die "Skill '${name}' not installed."

    local remote_skill
    remote_skill=$(gh_raw "${REGISTRY_BASE}/skills/${name}/SKILL.md") || die "Skill '${name}' not found in registry."
    local remote_hash
    remote_hash=$(echo "$remote_skill" | content_hash)
    local local_hash
    local_hash=$(echo "$(cat "${dir}/SKILL.md")" | content_hash)

    if [[ "$remote_hash" == "$local_hash" ]]; then
      dim "Skill '${name}' already up to date."
    else
      rm -rf "$dir"
      _install_single_skill "$name"
    fi
    return
  fi

  local found=0
  local dir="${CLAUDE_CONFIG_DIR}/skills"
  if [[ -d "$dir" ]]; then
    for d in "$dir"/*/; do
      [[ -d "$d" ]] || continue
      [[ -f "${d}SKILL.md" ]] || continue
      found=1
      local n
      n=$(basename "$d")
      local remote_skill
      remote_skill=$(gh_raw "${REGISTRY_BASE}/skills/${n}/SKILL.md") || continue
      local remote_hash
      remote_hash=$(echo "$remote_skill" | content_hash)
      local local_hash
      local_hash=$(echo "$(cat "${d}SKILL.md")" | content_hash)
      if [[ "$remote_hash" == "$local_hash" ]]; then
        dim "Skill '${n}' already up to date."
      else
        rm -rf "$d"
        _install_single_skill "$n" 2>/dev/null || true
      fi
    done
  fi

  if [[ $found -eq 0 ]]; then
    dim "No skills to update."
  fi
}

dispatch_skills() {
  local sub="${1:-}"
  if [[ -z "$sub" ]]; then
    sub=$(pick_one "Skills action:" "list" "install" "remove" "update") || exit 1
  fi
  case "$sub" in
    list)      cmd_skills_list ;;
    install)   shift 2>/dev/null || true; cmd_skills_install "$@" ;;
    remove)    cmd_skills_remove "${2:-}" ;;
    update)    cmd_skills_update "${2:-}" ;;
    *)         die "Unknown: crew skills $sub. Try: list, install, remove, update" ;;
  esac
}

