# ─────────────────────────────────────────────
# NOTIFICATIONS
# ─────────────────────────────────────────────
_ntfy_hook_script() { echo "${CLAUDE_CONFIG_DIR}/hooks/crew-ntfy.sh"; }

_ntfy_extract_topic() {
  local script
  script=$(_ntfy_hook_script)
  [[ -f "$script" ]] || return 1
  grep '^NTFY_TOPIC=' "$script" 2>/dev/null | head -1 | cut -d'"' -f2
}

_ntfy_write_script() {
  local topic="$1"
  local script
  script=$(_ntfy_hook_script)
  mkdir -p "$(dirname "$script")"
  cat > "$script" << 'HOOKEOF'
#!/usr/bin/env bash
NTFY_TOPIC="__TOPIC__"

INPUT=$(cat)
TYPE=$(echo "$INPUT" | python3 -c "import json,sys; print(json.load(sys.stdin).get('notification_type',''))" 2>/dev/null)
MSG=$(echo "$INPUT" | python3 -c "import json,sys; print(json.load(sys.stdin).get('message',''))" 2>/dev/null)
CWD=$(echo "$INPUT" | python3 -c "import json,sys; print(json.load(sys.stdin).get('cwd',''))" 2>/dev/null)
PROJECT=$(basename "$CWD")

case "$TYPE" in
  idle_prompt)       TITLE="Claude idle — $PROJECT"; TAGS="white_check_mark"; PRIO="default" ;;
  permission_prompt) TITLE="Permission needed — $PROJECT"; TAGS="lock"; PRIO="high" ;;
  auth_success)      TITLE="Auth success — $PROJECT"; TAGS="key"; PRIO="low" ;;
  elicitation_dialog) TITLE="Input needed — $PROJECT"; TAGS="question"; PRIO="high" ;;
  *)                 TITLE="Claude — $PROJECT"; TAGS="bell"; PRIO="default" ;;
esac

curl -sf \
  -H "Title: $TITLE" \
  -H "Tags: $TAGS" \
  -H "Priority: $PRIO" \
  -d "$MSG" \
  "ntfy.sh/$NTFY_TOPIC" >/dev/null 2>&1

exit 0
HOOKEOF
  sed -i '' "s|__TOPIC__|${topic}|" "$script"
  chmod +x "$script"
}

cmd_notification_setup() {
  local default_topic="crew-$(LC_ALL=C tr -dc 'a-f0-9' < /dev/urandom | head -c 8)"

  printf "Enter ntfy.sh topic [%s]: " "$default_topic"
  local topic
  read -r topic
  topic="${topic:-$default_topic}"

  _ntfy_write_script "$topic"

  local settings_file="${CLAUDE_CONFIG_DIR}/settings.json"
  local hook_script
  hook_script=$(_ntfy_hook_script)

  mkdir -p "$CLAUDE_CONFIG_DIR"

  python3 -c "
import json, os

path = '$settings_file'
script = '$hook_script'

if os.path.exists(path):
    with open(path) as f:
        settings = json.load(f)
else:
    settings = {}

hook_entry = {
    'hooks': [{
        'type': 'command',
        'command': script
    }]
}

hooks = settings.setdefault('hooks', {})
notif_hooks = hooks.get('Notification', [])

# Remove any existing crew/ntfy hook
notif_hooks = [h for h in notif_hooks if not
    any('crew-ntfy.sh' in hk.get('command', '') or 'ntfy.sh/' in hk.get('command', '')
        for hk in h.get('hooks', []))]

notif_hooks.append(hook_entry)
hooks['Notification'] = notif_hooks

with open(path, 'w') as f:
    json.dump(settings, f, indent=2)
    f.write('\n')
" || die "Failed to write settings."

  green "Notifications enabled (topic: ${topic})"
  echo ""
  echo "  All notification types are active:"
  echo "    idle_prompt        — Claude finished, waiting for input"
  echo "    permission_prompt  — Claude needs permission to proceed"
  echo "    auth_success       — Authentication completed"
  echo "    elicitation_dialog — Claude is asking for input"
  echo ""
  dim "Subscribe at: https://ntfy.sh/${topic}"
}

cmd_notification_status() {
  local topic
  if topic=$(_ntfy_extract_topic) && [[ -n "$topic" ]]; then
    green "Notifications: enabled (topic: ${topic})"
    dim "Subscribe at: https://ntfy.sh/${topic}"
  else
    dim "Notifications: not configured"
    dim "Run: crew notify setup"
  fi
}

cmd_notification_test() {
  local topic
  topic=$(_ntfy_extract_topic) || die "No notification hook configured. Run: crew notify setup"
  [[ -z "$topic" ]] && die "No notification hook configured. Run: crew notify setup"

  local project
  project=$(basename "$PWD")

  curl -sf \
    -H "Title: Claude idle — ${project}" \
    -H "Tags: white_check_mark" \
    -d "Test: Claude is waiting for input" \
    "ntfy.sh/${topic}" >/dev/null \
    && green "Test notification sent to topic '${topic}'" \
    || die "Failed to send notification."
}

cmd_notification_remove() {
  local settings_file="${CLAUDE_CONFIG_DIR}/settings.json"
  [[ -f "$settings_file" ]] || die "No settings file found."

  local topic
  topic=$(_ntfy_extract_topic) || die "No notification hook configured."
  [[ -z "$topic" ]] && die "No notification hook configured."

  python3 -c "
import json

path = '$settings_file'
with open(path) as f:
    settings = json.load(f)

hooks = settings.get('hooks', {})
notif_hooks = hooks.get('Notification', [])

notif_hooks = [h for h in notif_hooks if not
    any('crew-ntfy.sh' in hk.get('command', '') or 'ntfy.sh/' in hk.get('command', '')
        for hk in h.get('hooks', []))]

if notif_hooks:
    hooks['Notification'] = notif_hooks
else:
    hooks.pop('Notification', None)

if not hooks:
    settings.pop('hooks', None)

with open(path, 'w') as f:
    json.dump(settings, f, indent=2)
    f.write('\n')
" || die "Failed to update settings."

  local hook_script
  hook_script=$(_ntfy_hook_script)
  rm -f "$hook_script"

  green "Notification hook removed (was topic: ${topic})"
}

dispatch_notify() {
  local sub="${1:-}"
  if [[ -z "$sub" ]]; then
    sub=$(pick_one "Notification action:" "setup" "status" "test" "remove") || exit 1
  fi
  case "$sub" in
    setup)  cmd_notification_setup ;;
    status) cmd_notification_status ;;
    test)   cmd_notification_test ;;
    remove) cmd_notification_remove ;;
    *)      die "Unknown: crew notify $sub. Try: setup, status, test, remove" ;;
  esac
}

# ─────────────────────────────────────────────
# LAUNCH
# ─────────────────────────────────────────────
generate_workspace_file() {
  local ws="$1"
  local include_agents="${2:-false}"
  local prompt_file="${3:-}"
  local lead_path="${4:-}"
  local claude_config_dir="${5:-}"
  local ws_file="${CONFIG_DIR}/${ws}.code-workspace"

  python3 -c "
import json, os

with open('$(workspace_file "$ws")') as f:
    data = json.load(f)

folders = [{'path': p['path']} for p in data['projects']]

tasks = []

include_agents = '$include_agents' == 'true'
if include_agents:
    prompt_file = '$prompt_file'
    lead_path = '$lead_path'
    claude_config_dir = '$claude_config_dir'
    claude_cmd = 'claude --teammate-mode in-process \"\$(cat ' + json.dumps(prompt_file)[1:-1] + ')\"'
    if claude_config_dir:
        claude_cmd = \"CLAUDE_CONFIG_DIR='\" + claude_config_dir + \"' \" + claude_cmd
    tasks.append({
        'label': 'agents',
        'type': 'shell',
        'command': claude_cmd,
        'options': {'cwd': lead_path},
        'isBackground': True,
        'problemMatcher': [],
        'presentation': {
            'group': 'agents',
            'focus': True,
            'reveal': 'always'
        },
        'runOptions': {
            'runOn': 'folderOpen'
        }
    })

# Open an empty terminal per project
for p in data['projects']:
    tasks.append({
        'label': p['name'],
        'type': 'shell',
        'command': '',
        'options': {'cwd': p['path']},
        'isBackground': True,
        'problemMatcher': [],
        'presentation': {
            'group': 'terminals',
            'reveal': 'always'
        },
        'runOptions': {
            'runOn': 'folderOpen'
        }
    })

workspace = {
    'folders': folders,
    'settings': {
        'task.allowAutomaticTasks': 'on'
    },
    'tasks': {
        'version': '2.0.0',
        'tasks': tasks
    }
}

with open('$ws_file', 'w') as f:
    json.dump(workspace, f, indent=2)

print('$ws_file')
"
}

cmd_launch_up() {
  local ws_arg="${1:-}"
  local mode="${2:-all}"

  if [[ "$mode" == "-a" ]]; then mode="agents"; fi

  local ws
  ws=$(pick_workspace "$ws_arg")

  command -v claude &>/dev/null || die "claude not found. Install Claude Code first."

  local projects
  projects=$(read_projects "$ws")

  # Build prompt file
  local prompt_file="${CONFIG_DIR}/prompt-${ws}.md"
  {
    echo "Create an agent team and spawn these teammates:"
    while IFS='|' read -r name path role; do
      echo "- **$name** (working directory: $path): $role"
    done <<< "$projects"
    echo ""
    echo "Each teammate should cd into their project directory before starting work."
    echo "Create a shared task list so I can see status."
    echo "Wait for my instructions on what to build."
  } > "$prompt_file"

  local lead_path
  lead_path=$(echo "$projects" | head -1 | cut -d'|' -f2 | xargs dirname)

  # Detect editor
  local editor=""
  if command -v cursor &>/dev/null; then
    editor="cursor"
  elif command -v code &>/dev/null; then
    editor="code"
  fi

  # ── Agents only → tmux ──
  if [[ "$mode" == "agents" ]]; then
    command -v tmux &>/dev/null || die "tmux not found. Install with: brew install tmux"

    local session="crew-$ws"

    trap "cleanup_workspace '$ws'" EXIT

    if tmux has-session -t "$session" 2>/dev/null; then
      echo "Agent session already running. Attaching..."
      attach_session "$session"
      return
    fi

    echo ""
    blue "Launching agents: $ws"
    echo ""

    tmux new-session -d -s "$session" -c "$lead_path"
    local claude_cmd="claude \"\$(cat '$prompt_file')\""
    tmux send-keys -t "$session" "$claude_cmd" Enter

    echo "┌─────────────────────────────────────────┐"
    echo "│  Workspace: $ws (agents)                │"
    echo "│  Agent teams will spawn tmux panes.     │"
    echo "│                                         │"
    echo "│  Ctrl+B + arrows = switch panes         │"
    echo "│  Ctrl+B + n/p   = next/prev window      │"
    echo "│  Detach (esc) = tear down everything     │"
    echo "└─────────────────────────────────────────┘"
    echo ""

    attach_session "$session"
    return
  fi

  # ── Default: Cursor/VS Code with agents + terminals ──
  if [[ -n "$editor" ]]; then
    local ws_file
    ws_file=$(generate_workspace_file "$ws" "true" "$prompt_file" "$lead_path" "${CLAUDE_CONFIG_DIR:-}")

    $editor "$ws_file"

    echo ""
    green "Workspace '$ws' opened in $editor. Agents will auto-start."
    dim "   crew kill = tear down everything"
    echo ""
    return
  fi

  # Fallback: tmux (no editor found)
  command -v tmux &>/dev/null || die "tmux not found. Install with: brew install tmux"

  local session="crew-$ws"

  if tmux has-session -t "$session" 2>/dev/null; then
    echo "Agent session already running. Attaching..."
    attach_session "$session"
    return
  fi

  trap "cleanup_workspace '$ws'" EXIT

  echo ""
  blue "Launching agents (tmux): $ws"
  echo ""

  tmux new-session -d -s "$session" -c "$lead_path" -n "agents"
  local claude_cmd="claude \"\$(cat '$prompt_file')\""
  tmux send-keys -t "$session:agents" "$claude_cmd" Enter

  echo "┌─────────────────────────────────────────┐"
  echo "│  Workspace: $ws (tmux fallback)         │"
  echo "│                                         │"
  echo "│  No editor found — agents in tmux.      │"
  echo "│  Detach (esc) = tear down everything     │"
  echo "└─────────────────────────────────────────┘"
  echo ""

  attach_session "$session"
}

# ─────────────────────────────────────────────
# KILL
# ─────────────────────────────────────────────
cmd_kill() {
  local killed=0

  for session in $(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep '^crew-'); do
    local ws="${session#crew-}"
    cleanup_workspace "$ws"
    killed=1
  done

  for ws_file in "${CONFIG_DIR}"/*.code-workspace; do
    [[ -f "$ws_file" ]] || continue
    local ws
    ws=$(basename "$ws_file" .code-workspace)
    tmux has-session -t "crew-$ws" 2>/dev/null && continue
    cleanup_workspace "$ws"
    killed=1
  done

  [[ $killed -eq 0 ]] && echo "No crew sessions running."
}

