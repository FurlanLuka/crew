_ntfy_hook_script() { echo "${CLAUDE_CONFIG_DIR}/hooks/crew-ntfy.sh"; }

_ntfy_extract_topic() {
  local script
  script=$(_ntfy_hook_script)
  [[ -f "$script" ]] || return 1
  grep '^NTFY_TOPIC=' "$script" 2>/dev/null | head -1 | cut -d'"' -f2
}

_ntfy_write_script() {
  local topic="$1"
  local script
  script=$(_ntfy_hook_script)
  mkdir -p "$(dirname "$script")"
  cat > "$script" << 'HOOKEOF'
#!/usr/bin/env bash
NTFY_TOPIC="__TOPIC__"

INPUT=$(cat)
TYPE=$(echo "$INPUT" | python3 -c "import json,sys; print(json.load(sys.stdin).get('notification_type',''))" 2>/dev/null)
MSG=$(echo "$INPUT" | python3 -c "import json,sys; print(json.load(sys.stdin).get('message',''))" 2>/dev/null)
CWD=$(echo "$INPUT" | python3 -c "import json,sys; print(json.load(sys.stdin).get('cwd',''))" 2>/dev/null)
PROJECT=$(basename "$CWD")

case "$TYPE" in
  idle_prompt)       TITLE="Claude idle — $PROJECT"; TAGS="white_check_mark"; PRIO="default" ;;
  permission_prompt) TITLE="Permission needed — $PROJECT"; TAGS="lock"; PRIO="high" ;;
  auth_success)      TITLE="Auth success — $PROJECT"; TAGS="key"; PRIO="low" ;;
  elicitation_dialog) TITLE="Input needed — $PROJECT"; TAGS="question"; PRIO="high" ;;
  *)                 TITLE="Claude — $PROJECT"; TAGS="bell"; PRIO="default" ;;
esac

curl -sf \
  -H "Title: $TITLE" \
  -H "Tags: $TAGS" \
  -H "Priority: $PRIO" \
  -d "$MSG" \
  "ntfy.sh/$NTFY_TOPIC" >/dev/null 2>&1

exit 0
HOOKEOF
  sed -i '' "s|__TOPIC__|${topic}|" "$script"
  chmod +x "$script"
}

cmd_notification_setup() {
  local default_topic="crew-$(LC_ALL=C tr -dc 'a-f0-9' < /dev/urandom | head -c 8)"

  printf "Enter ntfy.sh topic [%s]: " "$default_topic"
  local topic
  read -r topic
  topic="${topic:-$default_topic}"

  _ntfy_write_script "$topic"

  local settings_file="${CLAUDE_CONFIG_DIR}/settings.json"
  local hook_script
  hook_script=$(_ntfy_hook_script)

  mkdir -p "$CLAUDE_CONFIG_DIR"

  python3 -c "
import json, os

path = '$settings_file'
script = '$hook_script'

if os.path.exists(path):
    with open(path) as f:
        settings = json.load(f)
else:
    settings = {}

hook_entry = {
    'hooks': [{
        'type': 'command',
        'command': script
    }]
}

hooks = settings.setdefault('hooks', {})
notif_hooks = hooks.get('Notification', [])

# Remove any existing crew/ntfy hook
notif_hooks = [h for h in notif_hooks if not
    any('crew-ntfy.sh' in hk.get('command', '') or 'ntfy.sh/' in hk.get('command', '')
        for hk in h.get('hooks', []))]

notif_hooks.append(hook_entry)
hooks['Notification'] = notif_hooks

with open(path, 'w') as f:
    json.dump(settings, f, indent=2)
    f.write('\n')
" || die "Failed to write settings."

  green "Notifications enabled (topic: ${topic})"
  echo ""
  echo "  All notification types are active:"
  echo "    idle_prompt        — Claude finished, waiting for input"
  echo "    permission_prompt  — Claude needs permission to proceed"
  echo "    auth_success       — Authentication completed"
  echo "    elicitation_dialog — Claude is asking for input"
  echo ""
  dim "Subscribe at: https://ntfy.sh/${topic}"
}

cmd_notification_status() {
  local topic
  if topic=$(_ntfy_extract_topic) && [[ -n "$topic" ]]; then
    green "Notifications: enabled (topic: ${topic})"
    dim "Subscribe at: https://ntfy.sh/${topic}"
  else
    dim "Notifications: not configured"
    dim "Run: crew notify setup"
  fi
}

cmd_notification_test() {
  local topic
  topic=$(_ntfy_extract_topic) || die "No notification hook configured. Run: crew notify setup"
  [[ -z "$topic" ]] && die "No notification hook configured. Run: crew notify setup"

  local project
  project=$(basename "$PWD")

  curl -sf \
    -H "Title: Claude idle — ${project}" \
    -H "Tags: white_check_mark" \
    -d "Test: Claude is waiting for input" \
    "ntfy.sh/${topic}" >/dev/null \
    && green "Test notification sent to topic '${topic}'" \
    || die "Failed to send notification."
}

cmd_notification_remove() {
  local settings_file="${CLAUDE_CONFIG_DIR}/settings.json"
  [[ -f "$settings_file" ]] || die "No settings file found."

  local topic
  topic=$(_ntfy_extract_topic) || die "No notification hook configured."
  [[ -z "$topic" ]] && die "No notification hook configured."

  python3 -c "
import json

path = '$settings_file'
with open(path) as f:
    settings = json.load(f)

hooks = settings.get('hooks', {})
notif_hooks = hooks.get('Notification', [])

notif_hooks = [h for h in notif_hooks if not
    any('crew-ntfy.sh' in hk.get('command', '') or 'ntfy.sh/' in hk.get('command', '')
        for hk in h.get('hooks', []))]

if notif_hooks:
    hooks['Notification'] = notif_hooks
else:
    hooks.pop('Notification', None)

if not hooks:
    settings.pop('hooks', None)

with open(path, 'w') as f:
    json.dump(settings, f, indent=2)
    f.write('\n')
" || die "Failed to update settings."

  local hook_script
  hook_script=$(_ntfy_hook_script)
  rm -f "$hook_script"

  green "Notification hook removed (was topic: ${topic})"
}

dispatch_notify() {
  local sub="${1:-}"
  if [[ -z "$sub" ]]; then
    sub=$(pick_one "Notification action:" "setup" "status" "test" "remove") || exit 1
  fi
  case "$sub" in
    setup)  cmd_notification_setup ;;
    status) cmd_notification_status ;;
    test)   cmd_notification_test ;;
    remove) cmd_notification_remove ;;
    *)      die "Unknown: crew notify $sub. Try: setup, status, test, remove" ;;
  esac
}

