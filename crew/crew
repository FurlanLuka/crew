# ─────────────────────────────────────────────
# ROUTER
# ─────────────────────────────────────────────
case "${1:-}" in
  # Namespace commands that need config
  agents)       resolve_config; dispatch_agents "${@:2}" ;;
  skills)       resolve_config; dispatch_skills "${@:2}" ;;
  profile)      resolve_config; dispatch_profile "${@:2}" ;;
  notify)       resolve_config; dispatch_notify "${@:2}" ;;
  update)       resolve_config; cmd_update ;;
  run)          resolve_config; cmd_agents_run "${2:-}" ;;

  # No config needed
  workspace)    dispatch_workspace "${@:2}" ;;
  project)      dispatch_project "${@:2}" ;;
  kill)         cmd_kill ;;
  help)         cmd_help ;;

  # Default: launch (needs config)
  "")           resolve_config; cmd_launch_up "" "all" ;;
  -a)           resolve_config; cmd_launch_up "" "agents" ;;
  *)
    if workspace_exists "$1"; then
      # Parse flags for workspace launch
      _launch_mode="all"
      _ws_arg="$1"
      shift
      for arg in "$@"; do
        case "$arg" in
          -a) _launch_mode="agents" ;;
        esac
      done
      resolve_config
      cmd_launch_up "$_ws_arg" "$_launch_mode"
    else
      die "Unknown command '$1'. Try: crew help"
    fi
    ;;
esac
