generate_workspace_file() {
  local ws="$1"
  local include_agents="${2:-false}"
  local prompt_file="${3:-}"
  local lead_path="${4:-}"
  local claude_config_dir="${5:-}"
  local ws_file="${CONFIG_DIR}/${ws}.code-workspace"

  python3 -c "
import json, os

with open('$(workspace_file "$ws")') as f:
    data = json.load(f)

folders = [{'path': p['path'], 'name': p['name']} for p in data['projects']]

tasks = []

include_agents = '$include_agents' == 'true'
if include_agents:
    prompt_file = '$prompt_file'
    lead_path = '$lead_path'
    claude_config_dir = '$claude_config_dir'
    claude_cmd = 'CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1 claude'
    claude_cmd += ' --teammate-mode in-process \"\$(cat ' + json.dumps(prompt_file)[1:-1] + ')\"'
    if claude_config_dir:
        claude_cmd = \"CLAUDE_CONFIG_DIR='\" + claude_config_dir + \"' \" + claude_cmd
    tasks.append({
        'label': 'agents',
        'type': 'shell',
        'command': claude_cmd,
        'options': {'cwd': lead_path},
        'isBackground': True,
        'problemMatcher': [],
        'presentation': {
            'group': 'agents',
            'focus': True,
            'reveal': 'always'
        },
        'runOptions': {
            'runOn': 'folderOpen'
        }
    })

# Open an empty terminal per project
for p in data['projects']:
    tasks.append({
        'label': p['name'],
        'type': 'shell',
        'command': '',
        'options': {'cwd': p['path']},
        'isBackground': True,
        'problemMatcher': [],
        'presentation': {
            'group': 'terminals',
            'reveal': 'always'
        },
        'runOptions': {
            'runOn': 'folderOpen'
        }
    })

workspace = {
    'folders': folders,
    'settings': {
        'task.allowAutomaticTasks': 'on'
    },
    'tasks': {
        'version': '2.0.0',
        'tasks': tasks
    }
}

with open('$ws_file', 'w') as f:
    json.dump(workspace, f, indent=2)

print('$ws_file')
"
}

cmd_launch_up() {
  local ws_arg="${1:-}"
  local mode="${2:-all}"

  if [[ "$mode" == "-a" ]]; then mode="agents"; fi

  local ws
  ws=$(pick_workspace "$ws_arg")

  command -v claude &>/dev/null || die "claude not found. Install Claude Code first."

  # Worktree selection
  local launch_ws="$ws"
  if has_worktrees "$ws"; then
    local wts
    wts=$(list_worktrees "$ws")
    local opts=()
    while IFS= read -r w; do
      [[ -n "$w" ]] && opts+=("$w")
    done <<< "$wts"
    opts+=("+ New worktree" "No worktree (original)")

    local choice
    choice=$(pick_one "Select worktree:" "${opts[@]}") || exit 1

    if [[ "$choice" == "+ New worktree" ]]; then
      printf "Worktree name: "
      local wt_name
      read -er wt_name
      if [[ -n "$wt_name" ]]; then
        cmd_worktree_create "$ws" "$wt_name"
        launch_ws=$(worktree_workspace_name "$ws" "${wt_name//\//-}")
      fi
    elif [[ "$choice" != "No worktree (original)" ]]; then
      launch_ws=$(worktree_workspace_name "$ws" "$choice")
    fi
  else
    printf "Worktree name (leave empty to skip): "
    local wt_name
    read -er wt_name
    if [[ -n "$wt_name" ]]; then
      cmd_worktree_create "$ws" "$wt_name"
      launch_ws=$(worktree_workspace_name "$ws" "${wt_name//\//-}")
    fi
  fi

  local projects
  projects=$(read_projects "$launch_ws")

  # Build prompt file
  local prompt_file="${CONFIG_DIR}/prompt-${launch_ws}.md"
  {
    echo "Create an agent team and spawn these teammates:"
    while IFS='|' read -r name path role; do
      echo "- **$name** (working directory: $path): $role"
    done <<< "$projects"
    echo ""
    if [[ "$launch_ws" == *--* ]]; then
      echo "IMPORTANT: Each project directory is a git worktree — an isolated working copy with its own branch."
      echo "All changes stay isolated from the main codebase until explicitly merged."
      echo ""
    fi
    echo "Each teammate should cd into their project directory before starting work."
    echo "Create a shared task list so I can see status."
    echo "Wait for my instructions on what to build."
  } > "$prompt_file"

  local lead_path
  lead_path=$(echo "$projects" | head -1 | cut -d'|' -f2 | xargs dirname)

  # Detect editor
  local editor=""
  if command -v cursor &>/dev/null; then
    editor="cursor"
  elif command -v code &>/dev/null; then
    editor="code"
  fi

  # ── Agents only → tmux ──
  if [[ "$mode" == "agents" ]]; then
    command -v tmux &>/dev/null || die "tmux not found. Install with: brew install tmux"

    local session="crew-$launch_ws"

    trap "cleanup_workspace '$launch_ws'" EXIT

    if tmux has-session -t "$session" 2>/dev/null; then
      echo "Agent session already running. Attaching..."
      attach_session "$session"
      return
    fi

    echo ""
    blue "Launching agents: $launch_ws"
    echo ""

    tmux new-session -d -s "$session" -c "$lead_path"
    local claude_cmd="CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1 claude \"\$(cat '$prompt_file')\""
    tmux send-keys -t "$session" "$claude_cmd" Enter

    echo "┌─────────────────────────────────────────┐"
    echo "│  Workspace: $launch_ws (agents)         │"
    echo "│  Agent teams will spawn tmux panes.     │"
    echo "│                                         │"
    echo "│  Ctrl+B + arrows = switch panes         │"
    echo "│  Ctrl+B + n/p   = next/prev window      │"
    echo "│  Detach (esc) = tear down everything     │"
    echo "└─────────────────────────────────────────┘"
    echo ""

    attach_session "$session"
    return
  fi

  # ── Default: Cursor/VS Code with agents + terminals ──
  if [[ -n "$editor" ]]; then
    local ws_file
    ws_file=$(generate_workspace_file "$launch_ws" "true" "$prompt_file" "$lead_path" "$_USER_CLAUDE_CONFIG_DIR")

    $editor "$ws_file"

    echo ""
    green "Workspace '$launch_ws' opened in $editor. Agents will auto-start."
    dim "   crew kill = tear down everything"
    echo ""
    return
  fi

  # Fallback: tmux (no editor found)
  command -v tmux &>/dev/null || die "tmux not found. Install with: brew install tmux"

  local session="crew-$launch_ws"

  if tmux has-session -t "$session" 2>/dev/null; then
    echo "Agent session already running. Attaching..."
    attach_session "$session"
    return
  fi

  trap "cleanup_workspace '$launch_ws'" EXIT

  echo ""
  blue "Launching agents (tmux): $launch_ws"
  echo ""

  tmux new-session -d -s "$session" -c "$lead_path" -n "agents"
  local claude_cmd="CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1 claude \"\$(cat '$prompt_file')\""
  tmux send-keys -t "$session:agents" "$claude_cmd" Enter

  echo "┌─────────────────────────────────────────┐"
  echo "│  Workspace: $launch_ws (tmux fallback)  │"
  echo "│                                         │"
  echo "│  No editor found — agents in tmux.      │"
  echo "│  Detach (esc) = tear down everything     │"
  echo "└─────────────────────────────────────────┘"
  echo ""

  attach_session "$session"
}

# ─────────────────────────────────────────────
# KILL
# ─────────────────────────────────────────────
cmd_kill() {
  local killed=0

  for session in $(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep '^crew-'); do
    local ws="${session#crew-}"
    cleanup_workspace "$ws"
    killed=1
  done

  for ws_file in "${CONFIG_DIR}"/*.code-workspace; do
    [[ -f "$ws_file" ]] || continue
    local ws
    ws=$(basename "$ws_file" .code-workspace)
    tmux has-session -t "crew-$ws" 2>/dev/null && continue
    cleanup_workspace "$ws"
    killed=1
  done

  [[ $killed -eq 0 ]] && echo "No crew sessions running."
}

