#!/usr/bin/env bash
# crew — Agent team launcher, workspace manager & package registry
#
# Launch:
#   crew [workspace]                     Launch in Cursor
#   crew [workspace] -a                  Launch agents only (tmux)
#
# Workspace & project management:
#   crew workspace [create|list|remove]
#   crew project [add|list|remove]
#   crew worktree [create|list|remove|push]
#
# Registry:
#   crew agents [list|install|remove|update|run]
#   crew skills [list|install|remove|update]
#   crew run [agent]                     Shortcut for agents run
#   crew update                          Update all agents+skills+profile
#
# Profile:
#   crew profile [install|show|update|remove]
#
# Notifications:
#   crew notify [setup|status|test|remove]
#
#   crew kill
#   crew help

set -euo pipefail

# ─────────────────────────────────────────────
# CONSTANTS
# ─────────────────────────────────────────────
CONFIG_DIR="${HOME}/.crew"
WORKSPACES_DIR="${CONFIG_DIR}/workspaces"

REGISTRY_REPO="FurlanLuka/homebrew-tap"
REGISTRY_BRANCH="main"
REGISTRY_BASE="registry"

mkdir -p "$WORKSPACES_DIR"

# ─────────────────────────────────────────────
# HELPERS — color & output
# ─────────────────────────────────────────────
red()    { printf "\033[31m%s\033[0m\n" "$1"; }
green()  { printf "\033[32m%s\033[0m\n" "$1"; }
blue()   { printf "\033[34m%s\033[0m\n" "$1"; }
bold()   { printf "\033[1m%s\033[0m\n" "$1"; }
dim()    { printf "\033[2m%s\033[0m\n" "$1"; }

die() { red "Error: $1"; exit 1; }

# ─────────────────────────────────────────────
# HELPERS — parsing & hashing
# ─────────────────────────────────────────────
parse_frontmatter() {
  local key="$1"
  sed -n '/^---$/,/^---$/p' | grep "^${key}:" | sed "s/^${key}:[[:space:]]*//"
}

content_hash() {
  shasum -a 256 | cut -d' ' -f1
}

# ─────────────────────────────────────────────
# HELPERS — pickers (gum + fallback)
# ─────────────────────────────────────────────
has_gum() { command -v gum &>/dev/null; }

pick_one() {
  local header="$1"; shift
  local opts=("$@")
  [[ ${#opts[@]} -eq 0 ]] && return 1

  if has_gum; then
    gum choose --header "$header" "${opts[@]}"
  else
    echo "$header" >&2
    local i=1
    for opt in "${opts[@]}"; do
      printf "  %d) %s\n" "$i" "$opt" >&2
      ((i++))
    done
    printf "Enter number: " >&2
    local choice
    read -r choice
    [[ "$choice" =~ ^[0-9]+$ ]] || return 1
    ((choice >= 1 && choice <= ${#opts[@]})) || return 1
    echo "${opts[$((choice-1))]}"
  fi
}

pick_many() {
  local header="$1"; shift
  local opts=("$@")
  [[ ${#opts[@]} -eq 0 ]] && return 1

  if has_gum; then
    gum choose --no-limit --header "$header" "${opts[@]}"
  else
    echo "$header" >&2
    local i=1
    for opt in "${opts[@]}"; do
      printf "  %d) %s\n" "$i" "$opt" >&2
      ((i++))
    done
    printf "Enter numbers (space-separated): " >&2
    local choices
    read -r choices
    for c in $choices; do
      [[ "$c" =~ ^[0-9]+$ ]] || continue
      ((c >= 1 && c <= ${#opts[@]})) || continue
      echo "${opts[$((c-1))]}"
    done
  fi
}

# ─────────────────────────────────────────────
# HELPERS — GitHub
# ─────────────────────────────────────────────
gh_api() {
  local endpoint="$1"
  local url="https://api.github.com/repos/${REGISTRY_REPO}/contents/${endpoint}?ref=${REGISTRY_BRANCH}"
  curl -sf -H "Accept: application/vnd.github.v3+json" "$url"
}

gh_raw() {
  local path="$1"
  local url="https://raw.githubusercontent.com/${REGISTRY_REPO}/${REGISTRY_BRANCH}/${path}"
  curl -sf "$url"
}

# ─────────────────────────────────────────────
# HELPERS — workspace
# ─────────────────────────────────────────────
workspace_file() { echo "$WORKSPACES_DIR/$1.json"; }

workspace_exists() {
  [[ -f "$(workspace_file "$1")" ]]
}

pick_workspace() {
  local ws="${1:-}"
  if [[ -n "$ws" ]]; then
    workspace_exists "$ws" || die "Workspace '$ws' not found."
    echo "$ws"
    return
  fi

  local workspaces=()
  for f in "$WORKSPACES_DIR"/*.json; do
    [[ -f "$f" ]] || continue
    local fname
    fname=$(basename "$f" .json)
    [[ "$fname" == *--* ]] && continue
    workspaces+=("$fname")
  done

  [[ ${#workspaces[@]} -eq 0 ]] && die "No workspaces. Create one with: crew workspace create <name>"

  pick_one "Select workspace:" "${workspaces[@]}" || exit 1
}

read_projects() {
  local ws="$1"
  python3 -c "
import json, sys
with open('$(workspace_file "$ws")') as f:
    data = json.load(f)
if not data['projects']:
    sys.exit(1)
for p in data['projects']:
    print(f\"{p['name']}|{p['path']}|{p['role']}\")
" 2>/dev/null || die "No projects in workspace '$ws'. Add some with: crew project add $ws"
}

# ─────────────────────────────────────────────
# HELPERS — worktree
# ─────────────────────────────────────────────
worktree_workspace_name() {
  local base="$1" wt_name="$2"
  echo "${base}--${wt_name}"
}

list_worktrees() {
  local base="$1"
  for f in "$WORKSPACES_DIR"/${base}--*.json; do
    [[ -f "$f" ]] || continue
    local fname
    fname=$(basename "$f" .json)
    echo "${fname#${base}--}"
  done
}

has_worktrees() {
  local base="$1"
  for f in "$WORKSPACES_DIR"/${base}--*.json; do
    [[ -f "$f" ]] && return 0
  done
  return 1
}

attach_session() {
  local session="$1"
  if [[ "${TERM_PROGRAM:-}" == "iTerm.app" ]]; then
    tmux -CC attach -t "$session"
  else
    tmux attach -t "$session"
  fi
}

cleanup_workspace() {
  local ws="$1"
  local session="crew-$ws"

  if tmux has-session -t "$session" 2>/dev/null; then
    tmux kill-session -t "$session"
    echo "Killed agent session: $session"
  fi

  rm -f "${CONFIG_DIR}/prompt-${ws}.md" 2>/dev/null

  local ws_file="${CONFIG_DIR}/${ws}.code-workspace"
  if [[ -f "$ws_file" ]]; then
    local process_name=""
    if command -v cursor &>/dev/null; then
      process_name="Cursor"
    elif command -v code &>/dev/null; then
      process_name="Code"
    fi
    if [[ -n "$process_name" ]]; then
      osascript -e "
        tell application \"System Events\"
          if exists process \"$process_name\" then
            tell process \"$process_name\"
              repeat with w in (every window)
                if name of w contains \"$ws\" then
                  click button 1 of w
                end if
              end repeat
            end tell
          end if
        end tell
      " 2>/dev/null || true
    fi
    rm -f "$ws_file"
  fi

  green "Workspace '$ws' torn down."
}

# ─────────────────────────────────────────────
# CONFIG — resolve CLAUDE_CONFIG_DIR
# ─────────────────────────────────────────────
resolve_config() {
  _USER_CLAUDE_CONFIG_DIR="${CLAUDE_CONFIG_DIR:-}"
  CLAUDE_CONFIG_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
  export CLAUDE_CONFIG_DIR
}

# ─────────────────────────────────────────────
# WORKSPACE COMMANDS
# ─────────────────────────────────────────────
cmd_workspace_create() {
  local name="${1:-}"
  [[ -z "$name" ]] && die "Usage: crew workspace create <name>"
  workspace_exists "$name" && die "Workspace '$name' already exists."

  python3 -c "
import json
data = {'name': '$name', 'projects': []}
with open('$(workspace_file "$name")', 'w') as f:
    json.dump(data, f, indent=2)
"
  green "Workspace '$name' created."
  echo "   Add projects with: crew project add $name"
}

cmd_workspace_list() {
  bold "Workspaces:"
  echo ""
  local found=0
  for f in "$WORKSPACES_DIR"/*.json; do
    [[ -f "$f" ]] || continue
    local name
    name=$(basename "$f" .json)
    [[ "$name" == *--* ]] && continue
    found=1
    local count
    count=$(python3 -c "import json; print(len(json.load(open('$f'))['projects']))" 2>/dev/null || echo 0)
    echo "  $name ($count projects)"
  done
  if [[ $found -eq 0 ]]; then
    dim "  No workspaces yet. Create one with: crew workspace create <name>"
  fi
}

cmd_workspace_remove() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    local workspaces=()
    for f in "$WORKSPACES_DIR"/*.json; do
      [[ -f "$f" ]] || continue
      local fname
      fname=$(basename "$f" .json)
      [[ "$fname" == *--* ]] && continue
      workspaces+=("$fname")
    done
    [[ ${#workspaces[@]} -eq 0 ]] && die "No workspaces to remove."
    name=$(pick_one "Select workspace to remove:" "${workspaces[@]}") || return 0
    [[ -z "$name" ]] && return 0
  fi
  workspace_exists "$name" || die "Workspace '$name' not found."

  # Cascade: remove all worktrees for this workspace
  if has_worktrees "$name"; then
    local wts
    wts=$(list_worktrees "$name")
    while IFS= read -r wt; do
      [[ -z "$wt" ]] && continue
      echo "Removing worktree '$wt'..."
      cmd_worktree_remove "$name" "$wt" 2>/dev/null || true
    done <<< "$wts"
  fi

  rm "$(workspace_file "$name")"
  green "Workspace '$name' removed."
}

dispatch_workspace() {
  local sub="${1:-}"
  if [[ -z "$sub" ]]; then
    sub=$(pick_one "Workspace action:" "create" "list" "remove") || exit 1
  fi
  case "$sub" in
    create) cmd_workspace_create "${2:-}" ;;
    list)   cmd_workspace_list ;;
    remove) cmd_workspace_remove "${2:-}" ;;
    *)      die "Unknown: crew workspace $sub. Try: create, list, remove" ;;
  esac
}

# ─────────────────────────────────────────────
# PROJECT COMMANDS
# ─────────────────────────────────────────────
cmd_project_add() {
  local ws="${1:-}"
  if [[ -z "$ws" ]]; then
    ws=$(pick_workspace "")
  fi
  workspace_exists "$ws" || die "Workspace '$ws' not found."

  printf "Project name: "
  read -er proj_name
  [[ -z "$proj_name" ]] && die "Name cannot be empty."

  printf "Project path: "
  read -er proj_path
  proj_path="${proj_path/#\~/$HOME}"
  [[ -d "$proj_path" ]] || die "Directory not found: $proj_path"
  proj_path="$(cd "$proj_path" && pwd)"

  printf "Agent role description (e.g. 'owns the backend API'): "
  read -er proj_role
  [[ -z "$proj_role" ]] && proj_role="works on $proj_name"

  python3 -c "
import json
with open('$(workspace_file "$ws")', 'r') as f:
    data = json.load(f)
proj = {
    'name': $(python3 -c "import json; print(json.dumps('$proj_name'))"),
    'path': $(python3 -c "import json; print(json.dumps('$proj_path'))"),
    'role': $(python3 -c "import json; print(json.dumps('$proj_role'))")
}
data['projects'].append(proj)
with open('$(workspace_file "$ws")', 'w') as f:
    json.dump(data, f, indent=2)
"
  green "Added '$proj_name' to workspace '$ws'."
}

cmd_project_list() {
  local ws="${1:-}"
  if [[ -z "$ws" ]]; then
    ws=$(pick_workspace "")
  fi
  workspace_exists "$ws" || die "Workspace '$ws' not found."

  bold "Projects in '$ws':"
  echo ""
  python3 -c "
import json
with open('$(workspace_file "$ws")') as f:
    data = json.load(f)
if not data['projects']:
    print('  No projects yet. Add one with: crew project add $ws')
for p in data['projects']:
    print(f\"  {p['name']}\")
    print(f\"    path:  {p['path']}\")
    print(f\"    role:  {p['role']}\")
    print()
"
}

cmd_project_remove() {
  local ws="${1:-}"
  local proj="${2:-}"
  [[ -z "$ws" || -z "$proj" ]] && die "Usage: crew project remove <workspace> <project>"
  workspace_exists "$ws" || die "Workspace '$ws' not found."

  python3 -c "
import json, sys
with open('$(workspace_file "$ws")', 'r') as f:
    data = json.load(f)
before = len(data['projects'])
data['projects'] = [p for p in data['projects'] if p['name'] != '$proj']
if len(data['projects']) == before:
    sys.exit(1)
with open('$(workspace_file "$ws")', 'w') as f:
    json.dump(data, f, indent=2)
" || die "Project '$proj' not found in workspace '$ws'."
  green "Removed '$proj' from workspace '$ws'."
}

dispatch_project() {
  local sub="${1:-}"
  if [[ -z "$sub" ]]; then
    sub=$(pick_one "Project action:" "add" "list" "remove") || exit 1
  fi
  case "$sub" in
    add)    cmd_project_add "${2:-}" ;;
    list)   cmd_project_list "${2:-}" ;;
    remove) cmd_project_remove "${2:-}" "${3:-}" ;;
    *)      die "Unknown: crew project $sub. Try: add, list, remove" ;;
  esac
}

# ─────────────────────────────────────────────
# WORKTREE COMMANDS
# ─────────────────────────────────────────────
cmd_worktree_create() {
  local ws="" wt_name="" from_branch=""
  for arg in "$@"; do
    case "$arg" in
      --from) from_branch="__next__" ;;
      *)
        if [[ "$from_branch" == "__next__" ]]; then
          from_branch="$arg"
        elif [[ -z "$ws" ]]; then
          ws="$arg"
        elif [[ -z "$wt_name" ]]; then
          wt_name="$arg"
        fi
        ;;
    esac
  done
  [[ -z "$ws" ]] && die "Usage: crew worktree create <workspace> [name] [--from <branch>]"
  workspace_exists "$ws" || die "Workspace '$ws' not found."

  local interactive=false
  if [[ -z "$wt_name" ]]; then
    interactive=true
    printf "Worktree name: "
    read -er wt_name
    [[ -z "$wt_name" ]] && die "Name cannot be empty."
  fi

  if [[ -z "$from_branch" ]] && [[ "$interactive" == true ]]; then
    printf "Base branch (leave empty for HEAD): "
    read -er from_branch
  fi

  # Validate name: alphanumeric, dots, hyphens, slashes — no double dashes
  [[ "$wt_name" =~ ^[a-zA-Z0-9._/-]+$ ]] || die "Invalid name. Use alphanumeric, dots, hyphens, or slashes."
  [[ "$wt_name" == *--* ]] && die "Name cannot contain '--'."

  # Filesystem-safe name (slashes → dashes), original kept for branch
  local wt_safe="${wt_name//\//-}"
  local branch="worktree-${wt_name}"

  local wt_ws
  wt_ws=$(worktree_workspace_name "$ws" "$wt_safe")
  workspace_exists "$wt_ws" && die "Worktree '$wt_name' already exists for workspace '$ws'."

  local projects
  projects=$(read_projects "$ws")

  # Create worktree config with worktree paths
  python3 -c "
import json, os

with open('$(workspace_file "$ws")') as f:
    base = json.load(f)

wt_data = {
    'name': '$wt_ws',
    'worktree': {
        'base_workspace': '$ws',
        'name': '$wt_safe'
    },
    'projects': []
}

for p in base['projects']:
    wt_path = os.path.join(p['path'], '.claude', 'worktrees', '$wt_safe')
    proj = dict(p)
    proj['path'] = wt_path
    wt_data['projects'].append(proj)

with open('$(workspace_file "$wt_ws")', 'w') as f:
    json.dump(wt_data, f, indent=2)
"

  # Create git worktrees for each project
  while IFS='|' read -r p_name p_path p_role; do
    local wt_dir="${p_path}/.claude/worktrees/${wt_safe}"

    echo "  Creating worktree for $p_name..."

    # Ensure .claude/worktrees/ is in .gitignore
    local gitignore="${p_path}/.gitignore"
    if [[ -f "$gitignore" ]]; then
      if ! grep -qF '.claude/worktrees/' "$gitignore" 2>/dev/null; then
        echo '.claude/worktrees/' >> "$gitignore"
      fi
    else
      echo '.claude/worktrees/' > "$gitignore"
    fi

    # Create the worktree
    if [[ -n "$from_branch" ]]; then
      (cd "$p_path" && git worktree add "$wt_dir" -b "$branch" "$from_branch" 2>/dev/null) \
        || die "Failed to create worktree for '$p_name'. Branch '$branch' may already exist or '$from_branch' not found."
    else
      (cd "$p_path" && git worktree add "$wt_dir" -b "$branch" 2>/dev/null) \
        || die "Failed to create worktree for '$p_name'. Branch '$branch' may already exist."
    fi

    # Copy .env files from original project
    for env_file in "$p_path"/.env*; do
      [[ -f "$env_file" ]] || continue
      cp "$env_file" "$wt_dir/"
    done

    # Run npm install if package.json exists
    if [[ -f "${wt_dir}/package.json" ]]; then
      echo "  Running npm install for $p_name..."
      (cd "$wt_dir" && npm install --silent 2>/dev/null) || true
    fi
  done <<< "$projects"

  if [[ "$wt_safe" != "$wt_name" ]]; then
    dim "  Normalized: $wt_name → $wt_safe"
  fi
  dim "  Branch: $branch"
  green "Worktree '$wt_safe' created for workspace '$ws'."
}

cmd_worktree_list() {
  local ws="${1:-}"
  if [[ -z "$ws" ]]; then
    ws=$(pick_workspace "")
  fi
  workspace_exists "$ws" || die "Workspace '$ws' not found."

  local wts
  wts=$(list_worktrees "$ws")

  if [[ -z "$wts" ]]; then
    dim "No worktrees for workspace '$ws'."
    return
  fi

  bold "Worktrees for '$ws':"
  echo ""
  while IFS= read -r wt_name; do
    [[ -z "$wt_name" ]] && continue
    echo "  $wt_name"
    local wt_ws
    wt_ws=$(worktree_workspace_name "$ws" "$wt_name")
    local wt_projects
    wt_projects=$(read_projects "$wt_ws" 2>/dev/null) || continue
    while IFS='|' read -r p_name p_path p_role; do
      local branch=""
      if [[ -d "$p_path" ]]; then
        branch=$(cd "$p_path" && git branch --show-current 2>/dev/null) || true
      fi
      if [[ -n "$branch" ]]; then
        dim "    $p_name → $branch"
      else
        dim "    $p_name (not found)"
      fi
    done <<< "$wt_projects"
  done <<< "$wts"
}

cmd_worktree_remove() {
  local ws="${1:-}"
  local wt_name="${2:-}"
  [[ -z "$ws" ]] && die "Usage: crew worktree remove <workspace> <name>"
  workspace_exists "$ws" || die "Workspace '$ws' not found."

  if [[ -z "$wt_name" ]]; then
    local wts
    wts=$(list_worktrees "$ws")
    [[ -z "$wts" ]] && die "No worktrees for workspace '$ws'."
    local opts=()
    while IFS= read -r w; do
      [[ -n "$w" ]] && opts+=("$w")
    done <<< "$wts"
    wt_name=$(pick_one "Select worktree to remove:" "${opts[@]}") || return 0
    [[ -z "$wt_name" ]] && return 0
  fi

  # Normalize slashes for lookup
  wt_name="${wt_name//\//-}"

  local wt_ws
  wt_ws=$(worktree_workspace_name "$ws" "$wt_name")
  workspace_exists "$wt_ws" || die "Worktree '$wt_name' not found for workspace '$ws'."

  # Kill any running session for this worktree workspace
  local session="crew-$wt_ws"
  if tmux has-session -t "$session" 2>/dev/null; then
    tmux kill-session -t "$session"
    echo "Killed session: $session"
  fi

  # Remove git worktrees using base workspace project paths
  local base_projects
  base_projects=$(read_projects "$ws")
  while IFS='|' read -r p_name p_path p_role; do
    local wt_dir="${p_path}/.claude/worktrees/${wt_name}"
    if [[ -d "$wt_dir" ]]; then
      echo "  Removing worktree for $p_name..."
      (cd "$p_path" && git worktree remove "$wt_dir" --force 2>/dev/null) || true
    fi
  done <<< "$base_projects"

  # Remove worktree config
  rm -f "$(workspace_file "$wt_ws")"

  green "Worktree '$wt_name' removed from workspace '$ws'."
}

cmd_worktree_push() {
  local ws="${1:-}"
  local wt_name="${2:-}"
  [[ -z "$ws" || -z "$wt_name" ]] && die "Usage: crew worktree push <workspace> <name>"
  workspace_exists "$ws" || die "Workspace '$ws' not found."

  # Normalize slashes for lookup
  wt_name="${wt_name//\//-}"

  local wt_ws
  wt_ws=$(worktree_workspace_name "$ws" "$wt_name")
  workspace_exists "$wt_ws" || die "Worktree '$wt_name' not found for workspace '$ws'."

  local wt_projects
  wt_projects=$(read_projects "$wt_ws")

  while IFS='|' read -r p_name p_path p_role; do
    if [[ -d "$p_path" ]]; then
      local branch
      branch=$(cd "$p_path" && git branch --show-current 2>/dev/null) || true
      echo "  Pushing $p_name ($branch)..."
      (cd "$p_path" && git push -u origin "$branch" 2>&1) || red "  Failed to push $p_name"
    else
      red "  Worktree path not found for $p_name"
    fi
  done <<< "$wt_projects"

  green "Pushed worktree '$wt_name' branches."
}

dispatch_worktree() {
  local sub="${1:-}"
  if [[ -z "$sub" ]]; then
    sub=$(pick_one "Worktree action:" "create" "list" "remove" "push") || exit 1
  fi
  case "$sub" in
    create) shift; cmd_worktree_create "$@" ;;
    list)   cmd_worktree_list "${2:-}" ;;
    remove) cmd_worktree_remove "${2:-}" "${3:-}" ;;
    push)   cmd_worktree_push "${2:-}" "${3:-}" ;;
    *)      die "Unknown: crew worktree $sub. Try: create, list, remove, push" ;;
  esac
}

# ─────────────────────────────────────────────
# REGISTRY FETCHERS
# ─────────────────────────────────────────────
fetch_registry_agent_names() {
  local response
  response=$(gh_api "${REGISTRY_BASE}/agents") || die "Failed to fetch agent registry."
  echo "$response" | python3 -c "
import json, sys
items = json.load(sys.stdin)
for item in items:
    name = item['name']
    if name.endswith('.md'):
        print(name[:-3])
" 2>/dev/null
}

fetch_registry_skill_names() {
  local response
  response=$(gh_api "${REGISTRY_BASE}/skills") || die "Failed to fetch skill registry."
  echo "$response" | python3 -c "
import json, sys
items = json.load(sys.stdin)
for item in items:
    if item['type'] == 'dir':
        print(item['name'])
" 2>/dev/null
}

get_installed_agent_names() {
  local dir="${CLAUDE_CONFIG_DIR}/agents"
  if [[ -d "$dir" ]]; then
    for f in "$dir"/*.md; do
      [[ -f "$f" ]] || continue
      basename "$f" .md
    done
  fi
}

get_installed_skill_names() {
  local dir="${CLAUDE_CONFIG_DIR}/skills"
  if [[ -d "$dir" ]]; then
    for d in "$dir"/*/; do
      [[ -d "$d" ]] || continue
      [[ -f "${d}SKILL.md" ]] || continue
      basename "$d"
    done
  fi
}

# ─────────────────────────────────────────────
# REGISTRY: AGENTS
# ─────────────────────────────────────────────
cmd_agents_list() {
  bold "Installed agents:"
  echo ""

  local found=0
  local dir="${CLAUDE_CONFIG_DIR}/agents"
  if [[ -d "$dir" ]]; then
    for f in "$dir"/*.md; do
      [[ -f "$f" ]] || continue
      found=1
      local name
      name=$(basename "$f" .md)
      local desc
      desc=$(parse_frontmatter "description" < "$f")
      if [[ -n "$desc" ]]; then
        printf "  %-24s %s\n" "$name" "$desc"
      else
        echo "  $name"
      fi
    done
  fi

  if [[ $found -eq 0 ]]; then
    dim "  No agents installed."
  fi
}

_install_single_agent() {
