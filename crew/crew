#!/usr/bin/env bash
# crew — Agent team launcher with workspace & project management
#
# Usage:
#   crew                                Select workspace and launch agents + servers
#   crew <workspace>                    Launch agents + servers for a workspace
#   crew servers [workspace]            Launch dev servers only
#   crew agents [workspace]             Launch agents only
#   crew workspace create <name>        Create a workspace
#   crew workspace list                 List workspaces
#   crew workspace delete <name>        Delete a workspace
#   crew project add <workspace>        Add a project (interactive)
#   crew project list <workspace>       List projects in a workspace
#   crew project remove <ws> <project>  Remove a project
#   crew kill                           Tear down all crew sessions
#   crew help                           Show this help

set -euo pipefail

CONFIG_DIR="${HOME}/.crew"
WORKSPACES_DIR="${CONFIG_DIR}/workspaces"

mkdir -p "$WORKSPACES_DIR"

# ─────────────────────────────────────────────
# HELPERS
# ─────────────────────────────────────────────
red()    { printf "\033[31m%s\033[0m\n" "$1"; }
green()  { printf "\033[32m%s\033[0m\n" "$1"; }
blue()   { printf "\033[34m%s\033[0m\n" "$1"; }
bold()   { printf "\033[1m%s\033[0m\n" "$1"; }
dim()    { printf "\033[2m%s\033[0m\n" "$1"; }

die() { red "❌ $1"; exit 1; }

workspace_file() { echo "$WORKSPACES_DIR/$1.json"; }

workspace_exists() {
  [[ -f "$(workspace_file "$1")" ]]
}

# Pick a workspace interactively or auto-select if only one
pick_workspace() {
  local ws="${1:-}"
  if [[ -n "$ws" ]]; then
    workspace_exists "$ws" || die "Workspace '$ws' not found."
    echo "$ws"
    return
  fi

  local workspaces=()
  for f in "$WORKSPACES_DIR"/*.json; do
    [[ -f "$f" ]] || continue
    workspaces+=("$(basename "$f" .json)")
  done

  [[ ${#workspaces[@]} -eq 0 ]] && die "No workspaces. Create one with: crew workspace create <name>"

  if [[ ${#workspaces[@]} -eq 1 ]]; then
    blue "Auto-selecting workspace: ${workspaces[0]}"
    echo "${workspaces[0]}"
    return
  fi

  echo "" >&2
  bold "Select a workspace:" >&2
  echo "" >&2
  for i in "${!workspaces[@]}"; do
    local count
    count=$(python3 -c "import json; print(len(json.load(open('$(workspace_file "${workspaces[$i]}")'))['projects']))" 2>/dev/null || echo 0)
    echo "  $((i + 1))) ${workspaces[$i]} ($count projects)" >&2
  done
  echo "" >&2
  printf "Enter number: " >&2
  read -r choice
  [[ "$choice" =~ ^[0-9]+$ ]] || die "Invalid selection."
  local idx=$((choice - 1))
  [[ $idx -ge 0 && $idx -lt ${#workspaces[@]} ]] || die "Invalid selection."
  echo "${workspaces[$idx]}"
}

# Read projects from workspace as "name|path|role|dev_command|port" lines
read_projects() {
  local ws="$1"
  python3 -c "
import json, sys
with open('$(workspace_file "$ws")') as f:
    data = json.load(f)
if not data['projects']:
    sys.exit(1)
for p in data['projects']:
    dev = p.get('dev_command', '')
    port = p.get('port', '')
    print(f\"{p['name']}|{p['path']}|{p['role']}|{dev}|{port}\")
" 2>/dev/null || die "No projects in workspace '$ws'. Add some with: crew project add $ws"
}

# Attach to tmux session (iTerm2 control mode if available)
attach_session() {
  local session="$1"
  if [[ "${TERM_PROGRAM:-}" == "iTerm.app" ]]; then
    tmux -CC attach -t "$session"
  else
    tmux attach -t "$session"
  fi
}

# Tear down everything for a workspace
cleanup_workspace() {
  local ws="$1"
  local session="crew-$ws"

  # Kill tmux session
  if tmux has-session -t "$session" 2>/dev/null; then
    tmux kill-session -t "$session"
    echo "Killed agent session: $session"
  fi

  # Clean up prompt file and shell config dirs
  rm -f "${CONFIG_DIR}/prompt-${ws}.md" 2>/dev/null
  rm -rf "${CONFIG_DIR}/shells/${ws}" 2>/dev/null

  # Close Cursor/VS Code workspace window (Electron apps need System Events)
  local ws_file="${CONFIG_DIR}/${ws}.code-workspace"
  if [[ -f "$ws_file" ]]; then
    local process_name=""
    if command -v cursor &>/dev/null; then
      process_name="Cursor"
    elif command -v code &>/dev/null; then
      process_name="Code"
    fi
    if [[ -n "$process_name" ]]; then
      osascript -e "
        tell application \"System Events\"
          if exists process \"$process_name\" then
            tell process \"$process_name\"
              repeat with w in (every window)
                if name of w contains \"$ws\" then
                  click button 1 of w
                end if
              end repeat
            end tell
          end if
        end tell
      " 2>/dev/null || true
    fi
    rm -f "$ws_file"
  fi

  green "✅ Workspace '$ws' torn down."
}

# ─────────────────────────────────────────────
# WORKSPACE COMMANDS
# ─────────────────────────────────────────────
cmd_workspace_create() {
  local name="${1:-}"
  [[ -z "$name" ]] && die "Usage: crew workspace create <name>"
  workspace_exists "$name" && die "Workspace '$name' already exists."

  python3 -c "
import json
data = {'name': '$name', 'projects': []}
with open('$(workspace_file "$name")', 'w') as f:
    json.dump(data, f, indent=2)
"
  green "✅ Workspace '$name' created."
  echo "   Add projects with: crew project add $name"
}

cmd_workspace_list() {
  bold "Workspaces:"
  echo ""
  local found=0
  for f in "$WORKSPACES_DIR"/*.json; do
    [[ -f "$f" ]] || continue
    found=1
    local name
    name=$(basename "$f" .json)
    local count
    count=$(python3 -c "import json; print(len(json.load(open('$f'))['projects']))" 2>/dev/null || echo 0)
    echo "  $name ($count projects)"
  done
  if [[ $found -eq 0 ]]; then
    dim "  No workspaces yet. Create one with: crew workspace create <name>"
  fi
}

cmd_workspace_delete() {
  local name="${1:-}"
  [[ -z "$name" ]] && die "Usage: crew workspace delete <name>"
  workspace_exists "$name" || die "Workspace '$name' not found."

  rm "$(workspace_file "$name")"
  green "✅ Workspace '$name' deleted."
}

# ─────────────────────────────────────────────
# PROJECT COMMANDS
# ─────────────────────────────────────────────
cmd_project_add() {
  local ws="${1:-}"
  [[ -z "$ws" ]] && die "Usage: crew project add <workspace>"
  workspace_exists "$ws" || die "Workspace '$ws' not found."

  printf "Project name: "
  read -er proj_name
  [[ -z "$proj_name" ]] && die "Name cannot be empty."

  printf "Project path: "
  read -er proj_path
  proj_path="${proj_path/#\~/$HOME}"
  [[ -d "$proj_path" ]] || die "Directory not found: $proj_path"
  proj_path="$(cd "$proj_path" && pwd)"

  printf "Agent role description (e.g. 'owns the backend API'): "
  read -er proj_role
  [[ -z "$proj_role" ]] && proj_role="works on $proj_name"

  printf "Dev server command (leave empty if none): "
  read -er dev_cmd

  local dev_port=""
  if [[ -n "$dev_cmd" ]]; then
    printf "Dev server port (leave empty if none): "
    read -er dev_port
  fi

  python3 -c "
import json
with open('$(workspace_file "$ws")', 'r') as f:
    data = json.load(f)
proj = {
    'name': $(python3 -c "import json; print(json.dumps('$proj_name'))"),
    'path': $(python3 -c "import json; print(json.dumps('$proj_path'))"),
    'role': $(python3 -c "import json; print(json.dumps('$proj_role'))")
}
dev_cmd = '''$dev_cmd'''
dev_port = '''$dev_port'''
if dev_cmd:
    proj['dev_command'] = dev_cmd
if dev_port:
    proj['port'] = dev_port
data['projects'].append(proj)
with open('$(workspace_file "$ws")', 'w') as f:
    json.dump(data, f, indent=2)
"
  green "✅ Added '$proj_name' to workspace '$ws'."
}

cmd_project_list() {
  local ws="${1:-}"
  [[ -z "$ws" ]] && die "Usage: crew project list <workspace>"
  workspace_exists "$ws" || die "Workspace '$ws' not found."

  bold "Projects in '$ws':"
  echo ""
  python3 -c "
import json
with open('$(workspace_file "$ws")') as f:
    data = json.load(f)
if not data['projects']:
    print('  No projects yet. Add one with: crew project add $ws')
for p in data['projects']:
    print(f\"  {p['name']}\")
    print(f\"    path:    {p['path']}\")
    print(f\"    role:    {p['role']}\")
    dev = p.get('dev_command', '')
    port = p.get('port', '')
    if dev:
        line = f'    server:  {dev}'
        if port:
            line += f' (port {port})'
        print(line)
    print()
"
}

cmd_project_remove() {
  local ws="${1:-}"
  local proj="${2:-}"
  [[ -z "$ws" || -z "$proj" ]] && die "Usage: crew project remove <workspace> <project>"
  workspace_exists "$ws" || die "Workspace '$ws' not found."

  python3 -c "
import json, sys
with open('$(workspace_file "$ws")', 'r') as f:
    data = json.load(f)
before = len(data['projects'])
data['projects'] = [p for p in data['projects'] if p['name'] != '$proj']
if len(data['projects']) == before:
    sys.exit(1)
with open('$(workspace_file "$ws")', 'w') as f:
    json.dump(data, f, indent=2)
" || die "Project '$proj' not found in workspace '$ws'."
  green "✅ Removed '$proj' from workspace '$ws'."
}

# ─────────────────────────────────────────────
# LAUNCH AGENTS
# ─────────────────────────────────────────────
cmd_launch_agents() {
  local ws
  ws=$(pick_workspace "${1:-}")
  local projects
  projects=$(read_projects "$ws")

  command -v tmux &>/dev/null || die "tmux not found. Install with: brew install tmux"
  command -v claude &>/dev/null || die "claude not found. Install Claude Code first."

  local session="crew-$ws"

  trap "cleanup_workspace '$ws'" EXIT

  if tmux has-session -t "$session" 2>/dev/null; then
    echo "Agent session already running. Attaching..."
    attach_session "$session"
    return
  fi

  # Build prompt and write to file
  local prompt_file="${CONFIG_DIR}/prompt-${ws}.md"
  {
    echo "Create an agent team and spawn these teammates:"
    while IFS='|' read -r name path role dev_cmd port; do
      echo "- **$name** (working directory: $path): $role"
    done <<< "$projects"
    echo ""
    echo "Each teammate should cd into their project directory before starting work."
    echo "Create a shared task list so I can see status."
    echo "Wait for my instructions on what to build."
  } > "$prompt_file"

  # Lead path = parent of first project
  local lead_path
  lead_path=$(echo "$projects" | head -1 | cut -d'|' -f2 | xargs dirname)

  echo ""
  blue "🚀 Launching agents: $ws"
  echo ""

  tmux new-session -d -s "$session" -c "$lead_path"
  local claude_cmd="claude \"\$(cat '$prompt_file')\""
  if [[ -n "${CLAUDE_CONFIG_DIR:-}" ]]; then
    claude_cmd="CLAUDE_CONFIG_DIR='${CLAUDE_CONFIG_DIR}' ${claude_cmd}"
  fi
  tmux send-keys -t "$session" "$claude_cmd" Enter

  echo "┌─────────────────────────────────────────┐"
  echo "│  Workspace: $ws (agents)                │"
  echo "│  Agent teams will spawn tmux panes.     │"
  echo "│                                         │"
  echo "│  Ctrl+B + arrows = switch panes         │"
  echo "│  Ctrl+B + n/p   = next/prev window      │"
  echo "│  Detach (esc) = tear down everything     │"
  echo "└─────────────────────────────────────────┘"
  echo ""

  attach_session "$session"
}

# ─────────────────────────────────────────────
# GENERATE WORKSPACE FILE & LAUNCH DEV SERVERS IN CURSOR
# ─────────────────────────────────────────────
generate_workspace_file() {
  local ws="$1"
  local include_agents="${2:-false}"
  local prompt_file="${3:-}"
  local lead_path="${4:-}"
  local claude_config_dir="${5:-}"
  local ws_file="${CONFIG_DIR}/${ws}.code-workspace"

  python3 -c "
import json, os

with open('$(workspace_file "$ws")') as f:
    data = json.load(f)

folders = [{'path': p['path']} for p in data['projects']]

tasks = []

# Agent task (runs claude with the team prompt)
include_agents = '$include_agents' == 'true'
if include_agents:
    prompt_file = '$prompt_file'
    lead_path = '$lead_path'
    claude_config_dir = '$claude_config_dir'
    claude_cmd = 'claude \"\$(cat ' + json.dumps(prompt_file)[1:-1] + ')\"'
    if claude_config_dir:
        claude_cmd = 'CLAUDE_CONFIG_DIR=\"' + claude_config_dir + '\" ' + claude_cmd
    ws_name = '$ws'
    tmux_cmd = \"tmux new-session -s crew-\" + ws_name + \" -c '\" + lead_path + \"' '\" + claude_cmd + \"'\"
    tasks.append({
        'label': 'agents',
        'type': 'shell',
        'command': tmux_cmd,
        'options': {'cwd': lead_path},
        'isBackground': True,
        'problemMatcher': [],
        'presentation': {
            'group': 'agents',
            'focus': True,
            'reveal': 'always'
        },
        'runOptions': {
            'runOn': 'folderOpen'
        }
    })

# Dev server tasks (ZDOTDIR: normal zsh with pre-typed command)
config_dir = '$CONFIG_DIR'
for p in data['projects']:
    dev_cmd = p.get('dev_command', '')
    if not dev_cmd:
        continue
    port = p.get('port', '')
    label = f\"{p['name']} server\"
    if port:
        label += f\" :{port}\"
    shell_dir = os.path.join(config_dir, 'shells', '$ws', p['name'])
    os.makedirs(shell_dir, exist_ok=True)
    zshrc = os.path.join(shell_dir, '.zshrc')
    with open(zshrc, 'w') as sf:
        sf.write('ZDOTDIR=\"\$HOME\"\n')
        sf.write('[[ -f \"\$HOME/.zshrc\" ]] && source \"\$HOME/.zshrc\"\n')
        sf.write(\"print -z '\" + dev_cmd + \"'\n\")
    cmd = \"ZDOTDIR='\" + shell_dir + \"' exec zsh -i\"
    tasks.append({
        'label': label,
        'type': 'shell',
        'command': cmd,
        'options': {'cwd': p['path']},
        'isBackground': True,
        'problemMatcher': [],
        'presentation': {
            'group': 'servers',
            'reveal': 'always'
        },
        'runOptions': {
            'runOn': 'folderOpen'
        }
    })

workspace = {
    'folders': folders,
    'settings': {
        'task.allowAutomaticTasks': 'on'
    },
    'tasks': {
        'version': '2.0.0',
        'tasks': tasks
    }
}

with open('$ws_file', 'w') as f:
    json.dump(workspace, f, indent=2)

print('$ws_file')
"
}

cmd_launch_servers() {
  local ws
  ws=$(pick_workspace "${1:-}")
  local projects
  projects=$(read_projects "$ws")

  # Detect editor
  local editor=""
  if command -v cursor &>/dev/null; then
    editor="cursor"
  elif command -v code &>/dev/null; then
    editor="code"
  else
    die "Neither 'cursor' nor 'code' CLI found. Install Cursor or VS Code CLI."
  fi

  local ws_file
  ws_file=$(generate_workspace_file "$ws" "false")

  echo ""
  blue "🚀 Opening dev servers in $editor: $ws"
  echo ""

  $editor "$ws_file"

  green "✅ Workspace opened. Press Enter in each terminal to start servers."
}

# ─────────────────────────────────────────────
# LAUNCH BOTH (agents + servers)
# ─────────────────────────────────────────────
cmd_launch_up() {
  local ws
  ws=$(pick_workspace "${1:-}")

  command -v claude &>/dev/null || die "claude not found. Install Claude Code first."

  local projects
  projects=$(read_projects "$ws")

  # Build prompt file (always, before workspace generation)
  local prompt_file="${CONFIG_DIR}/prompt-${ws}.md"
  {
    echo "Create an agent team and spawn these teammates:"
    while IFS='|' read -r name path role dev_cmd port; do
      echo "- **$name** (working directory: $path): $role"
    done <<< "$projects"
    echo ""
    echo "Each teammate should cd into their project directory before starting work."
    echo "Create a shared task list so I can see status."
    echo "Wait for my instructions on what to build."
  } > "$prompt_file"

  local lead_path
  lead_path=$(echo "$projects" | head -1 | cut -d'|' -f2 | xargs dirname)

  # Detect editor
  local editor=""
  if command -v cursor &>/dev/null; then
    editor="cursor"
  elif command -v code &>/dev/null; then
    editor="code"
  fi

  # ── Cursor-first path: everything in the editor ──
  if [[ -n "$editor" ]]; then
    local ws_file
    ws_file=$(generate_workspace_file "$ws" "true" "$prompt_file" "$lead_path" "${CLAUDE_CONFIG_DIR:-}")

    $editor "$ws_file"

    echo ""
    green "✅ Workspace '$ws' opened in $editor. Agents will auto-start."
    dim "   crew kill = tear down everything"
    echo ""
    return
  fi

  # ── Fallback: tmux (no editor found) ──
  command -v tmux &>/dev/null || die "tmux not found. Install with: brew install tmux"

  local session="crew-$ws"

  if tmux has-session -t "$session" 2>/dev/null; then
    echo "Agent session already running. Attaching..."
    attach_session "$session"
    return
  fi

  trap "cleanup_workspace '$ws'" EXIT

  echo ""
  blue "🚀 Launching agents (tmux): $ws"
  echo ""

  tmux new-session -d -s "$session" -c "$lead_path" -n "agents"
  local claude_cmd="claude \"\$(cat '$prompt_file')\""
  if [[ -n "${CLAUDE_CONFIG_DIR:-}" ]]; then
    claude_cmd="CLAUDE_CONFIG_DIR='${CLAUDE_CONFIG_DIR}' ${claude_cmd}"
  fi
  tmux send-keys -t "$session:agents" "$claude_cmd" Enter

  echo "┌─────────────────────────────────────────┐"
  echo "│  Workspace: $ws (tmux fallback)         │"
  echo "│                                         │"
  echo "│  No editor found — agents in tmux.      │"
  echo "│  Detach (esc) = tear down everything     │"
  echo "└─────────────────────────────────────────┘"
  echo ""

  attach_session "$session"
}

# ─────────────────────────────────────────────
# KILL
# ─────────────────────────────────────────────
cmd_kill() {
  local killed=0

  # Kill tmux-based sessions
  for session in $(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep '^crew-'); do
    local ws="${session#crew-}"
    cleanup_workspace "$ws"
    killed=1
  done

  # Clean up Cursor-only workspaces (no tmux session)
  for ws_file in "${CONFIG_DIR}"/*.code-workspace; do
    [[ -f "$ws_file" ]] || continue
    local ws
    ws=$(basename "$ws_file" .code-workspace)
    # Skip if already handled via tmux above
    tmux has-session -t "crew-$ws" 2>/dev/null && continue
    cleanup_workspace "$ws"
    killed=1
  done

  [[ $killed -eq 0 ]] && echo "No crew sessions running."
}

# ─────────────────────────────────────────────
# HELP
# ─────────────────────────────────────────────
cmd_help() {
  echo ""
  bold "crew — Agent team launcher"
  echo ""
  bold "  Launch:"
  echo "  crew [workspace]                  Launch in Cursor (agents + servers)"
  echo "  crew servers [workspace]          Launch dev servers only (Cursor)"
  echo "  crew agents [workspace]           Launch agents only (tmux)"
  echo ""
  bold "  Workspaces:"
  echo "  crew workspace create <name>      Create a workspace"
  echo "  crew workspace list               List all workspaces"
  echo "  crew workspace delete <name>      Delete a workspace"
  echo ""
  bold "  Projects:"
  echo "  crew project add <workspace>      Add a project (interactive)"
  echo "  crew project list <workspace>     List projects in a workspace"
  echo "  crew project remove <ws> <proj>   Remove a project"
  echo ""
  bold "  Session:"
  echo "  crew kill                         Kill all crew sessions"
  echo "  crew help                         Show this help"
  echo ""
}

# ─────────────────────────────────────────────
# ROUTER
# ─────────────────────────────────────────────
case "${1:-}" in
  workspace)
    case "${2:-}" in
      create) cmd_workspace_create "${3:-}" ;;
      list)   cmd_workspace_list ;;
      delete) cmd_workspace_delete "${3:-}" ;;
      *)      die "Unknown: crew workspace ${2:-}. Try: create, list, delete" ;;
    esac
    ;;
  project)
    case "${2:-}" in
      add)    cmd_project_add "${3:-}" ;;
      list)   cmd_project_list "${3:-}" ;;
      remove) cmd_project_remove "${3:-}" "${4:-}" ;;
      *)      die "Unknown: crew project ${2:-}. Try: add, list, remove" ;;
    esac
    ;;
  servers) cmd_launch_servers "${2:-}" ;;
  agents)  cmd_launch_agents "${2:-}" ;;
  up)      cmd_launch_up "${2:-}" ;;
  kill)    cmd_kill ;;
  help)    cmd_help ;;
  "")      cmd_launch_up "" ;;
  *)
    if workspace_exists "$1"; then
      cmd_launch_up "$1"
    else
      die "Unknown command '$1'. Try: crew help"
    fi
    ;;
esac
