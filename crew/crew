    green "Installed agent '${name}' to project (.claude/agents/${name}.md)"
  else
    green "Installed agent '${name}' globally (${target_dir}/${name}.md)"
  fi
}

cmd_agents_install() {
  local name="" project=false
  for arg in "$@"; do
    if [[ "$arg" == "-p" ]]; then
      project=true
    elif [[ -z "$name" ]]; then
      name="$arg"
    fi
  done

  if [[ -n "$name" ]]; then
    _install_single_agent "$name" "$project"
    return
  fi

  local names
  names=$(fetch_registry_agent_names) || return 1
  [[ -z "$names" ]] && { dim "No agents in registry."; return; }

  local opts=()
  while IFS= read -r n; do
    opts+=("$n")
  done <<< "$names"

  local selected
  selected=$(pick_many "Select agents to install:" "${opts[@]}") || return 0
  [[ -z "$selected" ]] && return 0

  while IFS= read -r n; do
    _install_single_agent "$n" "$project"
  done <<< "$selected"
}

cmd_agents_remove() {
  local name="${1:-}"

  if [[ -z "$name" ]]; then
    local names
    names=$(get_installed_agent_names)
    [[ -z "$names" ]] && die "No agents installed."

    local opts=()
    while IFS= read -r n; do
      opts+=("$n")
    done <<< "$names"

    name=$(pick_one "Select agent to remove:" "${opts[@]}") || return 0
    [[ -z "$name" ]] && return 0
  fi

  local file="${CLAUDE_CONFIG_DIR}/agents/${name}.md"
  [[ -f "$file" ]] || die "Agent '${name}' not found."
  rm "$file"
  green "Removed agent '${name}'."
}

cmd_agents_update() {
  local name="${1:-}"

  if [[ -n "$name" ]]; then
    local file="${CLAUDE_CONFIG_DIR}/agents/${name}.md"
    [[ -f "$file" ]] || die "Agent '${name}' not installed."

    local content
    content=$(gh_raw "${REGISTRY_BASE}/agents/${name}.md") || die "Agent '${name}' not found in registry."
    local remote_hash
    remote_hash=$(echo "$content" | content_hash)
    local local_hash
    local_hash=$(echo "$(cat "$file")" | content_hash)

    if [[ "$remote_hash" == "$local_hash" ]]; then
      dim "Agent '${name}' already up to date."
    else
      echo "$content" > "$file"
      green "Updated agent '${name}'."
    fi
    return
  fi

  local found=0
  local dir="${CLAUDE_CONFIG_DIR}/agents"
  if [[ -d "$dir" ]]; then
    for f in "$dir"/*.md; do
      [[ -f "$f" ]] || continue
      found=1
      local n
      n=$(basename "$f" .md)
      local content
      content=$(gh_raw "${REGISTRY_BASE}/agents/${n}.md") || continue
      local remote_hash
      remote_hash=$(echo "$content" | content_hash)
      local local_hash
      local_hash=$(echo "$(cat "$f")" | content_hash)
      if [[ "$remote_hash" == "$local_hash" ]]; then
        dim "Agent '${n}' already up to date."
      else
        echo "$content" > "$f"
        green "Updated agent '${n}'."
      fi
    done
  fi

  if [[ $found -eq 0 ]]; then
    dim "No agents to update."
  fi
}

cmd_agents_run() {
  local name="${1:-}"

  if [[ -z "$name" ]]; then
    local names
    names=$(get_installed_agent_names)
    [[ -z "$names" ]] && die "No agents installed. Run: crew agents install"

    local opts=()
    while IFS= read -r n; do
      opts+=("$n")
    done <<< "$names"

    name=$(pick_one "Select agent to run:" "${opts[@]}") || return 0
    [[ -z "$name" ]] && return 0
  fi

  [[ -f "${CLAUDE_CONFIG_DIR}/agents/${name}.md" ]] || die "Agent '${name}' not installed. Run: crew agents install ${name}"

  blue "Starting agent: ${name}"
  dim "  Config: ${CLAUDE_CONFIG_DIR}"
  echo ""

  exec claude --agent "$name"
}

dispatch_agents() {
  local sub="${1:-}"
  if [[ -z "$sub" ]]; then
    sub=$(pick_one "Agents action:" "list" "install" "remove" "update" "run") || exit 1
  fi
  case "$sub" in
    list)      cmd_agents_list ;;
    install)   shift 2>/dev/null || true; cmd_agents_install "$@" ;;
    remove)    cmd_agents_remove "${2:-}" ;;
    update)    cmd_agents_update "${2:-}" ;;
    run)       cmd_agents_run "${2:-}" ;;
    *)         die "Unknown: crew agents $sub. Try: list, install, remove, update, run" ;;
  esac
}

