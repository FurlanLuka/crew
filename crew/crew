cmd_profile_install() {
  local target="${CLAUDE_CONFIG_DIR}/CLAUDE.md"

  local content
  content=$(gh_raw "${REGISTRY_BASE}/profile/CLAUDE.md") || die "Failed to fetch profile from registry."

  mkdir -p "$CLAUDE_CONFIG_DIR"
  echo "$content" > "$target"
  green "Profile installed to ${target}"
}

cmd_profile_show() {
  local target="${CLAUDE_CONFIG_DIR}/CLAUDE.md"

  if [[ -f "$target" ]]; then
    cat "$target"
  else
    dim "No profile installed. Run: crew profile install"
  fi
}

cmd_profile_remove() {
  local target="${CLAUDE_CONFIG_DIR}/CLAUDE.md"

  if [[ -f "$target" ]]; then
    rm "$target"
    green "Profile removed (${target})"
  else
    die "No profile installed."
  fi
}

cmd_profile_update() {
  local target="${CLAUDE_CONFIG_DIR}/CLAUDE.md"

  if [[ ! -f "$target" ]]; then
    dim "No profile installed. Skipping."
    return
  fi

  local content
  content=$(gh_raw "${REGISTRY_BASE}/profile/CLAUDE.md") || die "Failed to fetch profile from registry."

  local remote_hash
  remote_hash=$(echo "$content" | content_hash)
  local local_hash
  local_hash=$(echo "$(cat "$target")" | content_hash)

  if [[ "$remote_hash" == "$local_hash" ]]; then
    dim "Profile already up to date."
  else
    echo "$content" > "$target"
    green "Updated profile (${target})."
  fi
}

dispatch_profile() {
  local sub="${1:-}"
  if [[ -z "$sub" ]]; then
    sub=$(pick_one "Profile action:" "install" "show" "update" "remove") || exit 1
  fi
  case "$sub" in
    install) cmd_profile_install ;;
    show)    cmd_profile_show ;;
    update)  cmd_profile_update ;;
    remove)  cmd_profile_remove ;;
    *)       die "Unknown: crew profile $sub. Try: install, show, update, remove" ;;
  esac
}

