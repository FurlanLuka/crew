# ─────────────────────────────────────────────
# ROUTER
# ─────────────────────────────────────────────
case "${1:-}" in
  agents)
    case "${2:-}" in
      list)      cmd_agents_list ;;
      install)   shift 2; cmd_agents_install "$@" ;;
      installed) cmd_agents_installed ;;
      remove)    cmd_agents_remove "${3:-}" ;;
      update)    cmd_agents_update "${3:-}" ;;
      run)       cmd_agents_run "${3:-}" ;;
      *)         die "Unknown: ccm agents ${2:-}. Try: list, install, installed, remove, update, run" ;;
    esac
    ;;
  skills)
    case "${2:-}" in
      list)      cmd_skills_list ;;
      install)   shift 2; cmd_skills_install "$@" ;;
      installed) cmd_skills_installed ;;
      remove)    cmd_skills_remove "${3:-}" ;;
      update)    cmd_skills_update "${3:-}" ;;
      *)         die "Unknown: ccm skills ${2:-}. Try: list, install, installed, remove, update" ;;
    esac
    ;;
  profile)
    case "${2:-}" in
      pull)   cmd_profile_pull ;;
      show)   cmd_profile_show ;;
      remove) cmd_profile_remove ;;
      *)      die "Unknown: ccm profile ${2:-}. Try: pull, show, remove" ;;
    esac
    ;;
  notification)
    case "${2:-}" in
      setup)  cmd_notification_setup ;;
      status) cmd_notification_status ;;
      test)   cmd_notification_test ;;
      remove) cmd_notification_remove ;;
      *)      die "Unknown: ccm notification ${2:-}. Try: setup, status, test, remove" ;;
    esac
    ;;
  install) cmd_install "${2:-}" ;;
  update)  cmd_update ;;
  help) cmd_help ;;
  "")   cmd_help ;;
  *)    die "Unknown command '${1:-}'. Try: ccm help" ;;
esac
