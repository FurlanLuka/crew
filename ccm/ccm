#!/usr/bin/env bash
# ccm — Claude Code Manager
# Package manager for Claude Code agents and skills.
#
# Usage:
#   ccm agents list                    List available agents from registry
#   ccm agents install [name]          Install agent (interactive picker if no name)
#   ccm agents install [name] -p       Install to current project
#   ccm agents installed               List installed agents
#   ccm agents remove <name>           Remove an agent
#   ccm agents update [name]           Update agent(s)
#   ccm agents run [name]              Run an installed agent
#   ccm skills list                    List available skills from registry
#   ccm skills install [name]          Install skill (interactive picker if no name)
#   ccm skills install [name] -p       Install to current project
#   ccm skills installed               List installed skills
#   ccm skills remove <name>           Remove a skill
#   ccm skills update [name]           Update skill(s)
#   ccm profile pull                   Pull global CLAUDE.md from registry
#   ccm profile show                   Show current global CLAUDE.md
#   ccm profile remove                 Remove global CLAUDE.md
#   ccm notification setup              Set up push notifications via ntfy.sh
#   ccm notification status             Show notification config
#   ccm notification test               Send a test notification
#   ccm notification remove             Remove notification hook
#   ccm install [-p]                   Install all agents, skills, and profile
#   ccm update                         Smart-update all installed items
#   ccm help                           Show this help

set -euo pipefail

CLAUDE_CONFIG_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
REGISTRY_REPO="FurlanLuka/homebrew-tap"
REGISTRY_BRANCH="main"
REGISTRY_BASE="registry"

# ─────────────────────────────────────────────
# HELPERS
# ─────────────────────────────────────────────
red()    { printf "\033[31m%s\033[0m\n" "$1"; }
green()  { printf "\033[32m%s\033[0m\n" "$1"; }
blue()   { printf "\033[34m%s\033[0m\n" "$1"; }
bold()   { printf "\033[1m%s\033[0m\n" "$1"; }
dim()    { printf "\033[2m%s\033[0m\n" "$1"; }

die() { red "Error: $1"; exit 1; }

# Parse YAML frontmatter from .md content on stdin
# Extracts a single key value from --- delimited frontmatter
parse_frontmatter() {
  local key="$1"
  sed -n '/^---$/,/^---$/p' | grep "^${key}:" | sed "s/^${key}:[[:space:]]*//"
}

# SHA-256 hash of stdin
content_hash() {
  shasum -a 256 | cut -d' ' -f1
}

# SHA-256 hash of a file
file_hash() {
  shasum -a 256 < "$1" 2>/dev/null | cut -d' ' -f1
}

# Interactive picker: check for gum (charmbracelet)
has_gum() { command -v gum &>/dev/null; }

# Single-select picker
# Usage: pick_one "header" option1 option2 ...
pick_one() {
  local header="$1"; shift
  local opts=("$@")
  [[ ${#opts[@]} -eq 0 ]] && return 1

  if has_gum; then
    gum choose --header "$header" "${opts[@]}"
  else
    echo "$header" >&2
    local i=1
    for opt in "${opts[@]}"; do
      printf "  %d) %s\n" "$i" "$opt" >&2
      ((i++))
    done
    printf "Enter number: " >&2
    local choice
    read -r choice
    [[ "$choice" =~ ^[0-9]+$ ]] || return 1
    ((choice >= 1 && choice <= ${#opts[@]})) || return 1
    echo "${opts[$((choice-1))]}"
  fi
}

# Multi-select picker
# Usage: pick_many "header" option1 option2 ...
# Returns newline-separated selections
pick_many() {
  local header="$1"; shift
  local opts=("$@")
  [[ ${#opts[@]} -eq 0 ]] && return 1

  if has_gum; then
    gum choose --no-limit --header "$header" "${opts[@]}"
  else
    echo "$header" >&2
    local i=1
    for opt in "${opts[@]}"; do
      printf "  %d) %s\n" "$i" "$opt" >&2
      ((i++))
    done
    printf "Enter numbers (space-separated): " >&2
    local choices
    read -r choices
    for c in $choices; do
      [[ "$c" =~ ^[0-9]+$ ]] || continue
      ((c >= 1 && c <= ${#opts[@]})) || continue
      echo "${opts[$((c-1))]}"
    done
  fi
}

# GitHub API helper
gh_api() {
  local endpoint="$1"
  local url="https://api.github.com/repos/${REGISTRY_REPO}/contents/${endpoint}?ref=${REGISTRY_BRANCH}"
  curl -sf -H "Accept: application/vnd.github.v3+json" "$url"
}

# Raw file download
gh_raw() {
  local path="$1"
  local url="https://raw.githubusercontent.com/${REGISTRY_REPO}/${REGISTRY_BRANCH}/${path}"
  curl -sf "$url"
}

# ─────────────────────────────────────────────
# REGISTRY FETCHERS
# ─────────────────────────────────────────────
fetch_registry_agent_names() {
  local response
  response=$(gh_api "${REGISTRY_BASE}/agents") || die "Failed to fetch agent registry."
  echo "$response" | python3 -c "
import json, sys
items = json.load(sys.stdin)
for item in items:
    name = item['name']
    if name.endswith('.md'):
        print(name[:-3])
" 2>/dev/null
}

fetch_registry_skill_names() {
  local response
  response=$(gh_api "${REGISTRY_BASE}/skills") || die "Failed to fetch skill registry."
  echo "$response" | python3 -c "
import json, sys
items = json.load(sys.stdin)
for item in items:
    if item['type'] == 'dir':
        print(item['name'])
" 2>/dev/null
}

get_installed_agent_names() {
  local global_names=""
  local global_dir="${CLAUDE_CONFIG_DIR}/agents"
  if [[ -d "$global_dir" ]]; then
    for f in "$global_dir"/*.md; do
      [[ -f "$f" ]] || continue
      local n
      n=$(basename "$f" .md)
      global_names="${global_names:+${global_names}
}${n}"
      echo "$n"
    done
  fi
  if [[ -d ".claude/agents" ]]; then
    for f in .claude/agents/*.md; do
      [[ -f "$f" ]] || continue
      local n
      n=$(basename "$f" .md)
      # Deduplicate against global names
      if [[ -n "$global_names" ]] && echo "$global_names" | grep -qx "$n"; then
        continue
      fi
      echo "$n"
    done
  fi
}

# ─────────────────────────────────────────────
# AGENTS
# ─────────────────────────────────────────────
cmd_agents_list() {
  bold "Available agents:"
  echo ""

  local names
  names=$(fetch_registry_agent_names) || true

  if [[ -z "$names" ]]; then
    dim "  No agents in registry yet."
    return
  fi

  while IFS= read -r name; do
    local content
    content=$(gh_raw "${REGISTRY_BASE}/agents/${name}.md") || continue
    local desc
    desc=$(echo "$content" | parse_frontmatter "description")
    if [[ -n "$desc" ]]; then
      printf "  %-24s %s\n" "$name" "$desc"
    else
      echo "  $name"
    fi
  done <<< "$names"
}

_install_single_agent() {
  local name="$1"
  local project="${2:-false}"

  local target_dir
  if [[ "$project" == true ]]; then
    target_dir=".claude/agents"
  else
    target_dir="${CLAUDE_CONFIG_DIR}/agents"
  fi

  mkdir -p "$target_dir"

  local content
  content=$(gh_raw "${REGISTRY_BASE}/agents/${name}.md") || die "Agent '${name}' not found in registry."

  echo "$content" > "${target_dir}/${name}.md"

  if [[ "$project" == true ]]; then
    green "Installed agent '${name}' to project (.claude/agents/${name}.md)"
  else
    green "Installed agent '${name}' globally (${target_dir}/${name}.md)"
  fi
}

cmd_agents_install() {
  local name="" project=false
  for arg in "$@"; do
    if [[ "$arg" == "-p" ]]; then
      project=true
    elif [[ -z "$name" ]]; then
      name="$arg"
    fi
  done

  if [[ -n "$name" ]]; then
    _install_single_agent "$name" "$project"
    return
  fi

  # Interactive: pick from registry
  local names
  names=$(fetch_registry_agent_names) || return 1
  [[ -z "$names" ]] && { dim "No agents in registry."; return; }

  local opts=()
  while IFS= read -r n; do
    opts+=("$n")
  done <<< "$names"

  local selected
  selected=$(pick_many "Select agents to install:" "${opts[@]}") || return 0
  [[ -z "$selected" ]] && return 0

  while IFS= read -r n; do
    _install_single_agent "$n" "$project"
  done <<< "$selected"
}

cmd_agents_installed() {
  bold "Installed agents:"
  echo ""

  local found=0

  # Global agents
  local global_dir="${CLAUDE_CONFIG_DIR}/agents"
  if [[ -d "$global_dir" ]]; then
    for f in "$global_dir"/*.md; do
      [[ -f "$f" ]] || continue
      found=1
      local name
      name=$(basename "$f" .md)
      local desc
      desc=$(parse_frontmatter "description" < "$f")
      if [[ -n "$desc" ]]; then
        printf "  %-24s %s  (global)\n" "$name" "$desc"
      else
        printf "  %-24s (global)\n" "$name"
      fi
    done
  fi

  # Project agents
  if [[ -d ".claude/agents" ]]; then
    for f in .claude/agents/*.md; do
      [[ -f "$f" ]] || continue
      found=1
      local name
      name=$(basename "$f" .md)
      local desc
      desc=$(parse_frontmatter "description" < "$f")
      if [[ -n "$desc" ]]; then
        printf "  %-24s %s  (project)\n" "$name" "$desc"
      else
        printf "  %-24s (project)\n" "$name"
      fi
    done
  fi

  if [[ $found -eq 0 ]]; then
    dim "  No agents installed."
  fi
}

cmd_agents_remove() {
  local name="${1:-}"
  [[ -z "$name" ]] && die "Usage: ccm agents remove <name>"

  local removed=false

  # Try project first
  if [[ -f ".claude/agents/${name}.md" ]]; then
    rm ".claude/agents/${name}.md"
    green "Removed agent '${name}' from project."
    removed=true
  fi

  # Try global
  local global_file="${CLAUDE_CONFIG_DIR}/agents/${name}.md"
  if [[ -f "$global_file" ]]; then
    rm "$global_file"
    green "Removed agent '${name}' from global."
    removed=true
  fi

  if [[ "$removed" == false ]]; then
    die "Agent '${name}' not found."
  fi
}

cmd_agents_update() {
  local name="${1:-}"

  if [[ -n "$name" ]]; then
    # Update single agent
    local global_file="${CLAUDE_CONFIG_DIR}/agents/${name}.md"
    local project_file=".claude/agents/${name}.md"

    local content
    content=$(gh_raw "${REGISTRY_BASE}/agents/${name}.md") || die "Agent '${name}' not found in registry."
    local remote_hash
    remote_hash=$(echo "$content" | content_hash)

    if [[ -f "$project_file" ]]; then
      local local_hash
      local_hash=$(echo "$(cat "$project_file")" | content_hash)
      if [[ "$remote_hash" == "$local_hash" ]]; then
        dim "Agent '${name}' already up to date (project)."
      else
        echo "$content" > "$project_file"
        green "Updated agent '${name}' (project)."
      fi
    fi

    if [[ -f "$global_file" ]]; then
      local local_hash
      local_hash=$(echo "$(cat "$global_file")" | content_hash)
      if [[ "$remote_hash" == "$local_hash" ]]; then
        dim "Agent '${name}' already up to date (global)."
      else
        echo "$content" > "$global_file"
        green "Updated agent '${name}' (global)."
      fi
    fi

    [[ ! -f "$project_file" && ! -f "$global_file" ]] && die "Agent '${name}' not installed."
    return
  fi

  # Update all installed agents
  local found=0

  local global_dir="${CLAUDE_CONFIG_DIR}/agents"
  if [[ -d "$global_dir" ]]; then
    for f in "$global_dir"/*.md; do
      [[ -f "$f" ]] || continue
      found=1
      local n
      n=$(basename "$f" .md)
      local content
      content=$(gh_raw "${REGISTRY_BASE}/agents/${n}.md") || continue
      local remote_hash
      remote_hash=$(echo "$content" | content_hash)
      local local_hash
      local_hash=$(echo "$(cat "$f")" | content_hash)
      if [[ "$remote_hash" == "$local_hash" ]]; then
        dim "Agent '${n}' already up to date (global)."
      else
        echo "$content" > "$f"
        green "Updated agent '${n}' (global)."
      fi
    done
  fi

  if [[ -d ".claude/agents" ]]; then
    for f in .claude/agents/*.md; do
      [[ -f "$f" ]] || continue
      found=1
      local n
      n=$(basename "$f" .md)
      local content
      content=$(gh_raw "${REGISTRY_BASE}/agents/${n}.md") || continue
      local remote_hash
      remote_hash=$(echo "$content" | content_hash)
      local local_hash
      local_hash=$(echo "$(cat "$f")" | content_hash)
      if [[ "$remote_hash" == "$local_hash" ]]; then
        dim "Agent '${n}' already up to date (project)."
      else
        echo "$content" > "$f"
        green "Updated agent '${n}' (project)."
      fi
    done
  fi

  if [[ $found -eq 0 ]]; then
    dim "No agents to update."
  fi
}

cmd_agents_run() {
  local name="${1:-}"

  if [[ -z "$name" ]]; then
    local names
    names=$(get_installed_agent_names)
    [[ -z "$names" ]] && die "No agents installed. Run: ccm agents install"

    local opts=()
    while IFS= read -r n; do
      opts+=("$n")
    done <<< "$names"

    name=$(pick_one "Select agent to run:" "${opts[@]}") || return 0
    [[ -z "$name" ]] && return 0
  fi

  # Verify installed
  local found=false
  [[ -f "${CLAUDE_CONFIG_DIR}/agents/${name}.md" ]] && found=true
  [[ -f ".claude/agents/${name}.md" ]] && found=true
  [[ "$found" == false ]] && die "Agent '${name}' not installed. Run: ccm agents install ${name}"

  exec claude --agent "$name"
}

# ─────────────────────────────────────────────
# SKILLS
# ─────────────────────────────────────────────
cmd_skills_list() {
  bold "Available skills:"
  echo ""

  local names
  names=$(fetch_registry_skill_names) || true

  if [[ -z "$names" ]]; then
    dim "  No skills in registry yet."
    return
  fi

  while IFS= read -r name; do
    local content
    content=$(gh_raw "${REGISTRY_BASE}/skills/${name}/SKILL.md") || continue
    local desc
    desc=$(echo "$content" | parse_frontmatter "description")
    if [[ -n "$desc" ]]; then
      printf "  %-24s %s\n" "$name" "$desc"
    else
      echo "  $name"
    fi
  done <<< "$names"
}

_install_single_skill() {
  local name="$1"
  local project="${2:-false}"

  local target_dir
  if [[ "$project" == true ]]; then
    target_dir=".claude/skills/${name}"
  else
    target_dir="${CLAUDE_CONFIG_DIR}/skills/${name}"
  fi

  mkdir -p "$target_dir"

  # List files in skill directory
  local response
  response=$(gh_api "${REGISTRY_BASE}/skills/${name}") || die "Skill '${name}' not found in registry."

  local files
  files=$(echo "$response" | python3 -c "
import json, sys

def list_files(items, prefix=''):
    for item in items:
        path = prefix + item['name'] if prefix else item['name']
        if item['type'] == 'file':
            print(path)

items = json.load(sys.stdin)
list_files(items)
" 2>/dev/null) || die "Failed to parse skill contents."

  while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    local content
    content=$(gh_raw "${REGISTRY_BASE}/skills/${name}/${file}") || { red "Failed to download: ${file}"; continue; }

    # Create subdirectories if needed
    local file_dir
    file_dir=$(dirname "$file")
    if [[ "$file_dir" != "." ]]; then
      mkdir -p "${target_dir}/${file_dir}"
    fi

    echo "$content" > "${target_dir}/${file}"
  done <<< "$files"

  # Handle subdirectories (one level deep)
  local dirs
  dirs=$(echo "$response" | python3 -c "
import json, sys
items = json.load(sys.stdin)
for item in items:
    if item['type'] == 'dir':
        print(item['name'])
" 2>/dev/null) || true

  while IFS= read -r subdir; do
    [[ -z "$subdir" ]] && continue
    mkdir -p "${target_dir}/${subdir}"

    local sub_response
    sub_response=$(gh_api "${REGISTRY_BASE}/skills/${name}/${subdir}") || continue

    local sub_files
    sub_files=$(echo "$sub_response" | python3 -c "
import json, sys
items = json.load(sys.stdin)
for item in items:
    if item['type'] == 'file':
        print(item['name'])
" 2>/dev/null) || continue

    while IFS= read -r sf; do
      [[ -z "$sf" ]] && continue
      local sc
      sc=$(gh_raw "${REGISTRY_BASE}/skills/${name}/${subdir}/${sf}") || continue
      echo "$sc" > "${target_dir}/${subdir}/${sf}"
    done <<< "$sub_files"
  done <<< "$dirs"

  if [[ "$project" == true ]]; then
    green "Installed skill '${name}' to project (.claude/skills/${name}/)"
  else
    green "Installed skill '${name}' globally (${target_dir}/)"
  fi
}

cmd_skills_install() {
  local name="" project=false
  for arg in "$@"; do
    if [[ "$arg" == "-p" ]]; then
      project=true
    elif [[ -z "$name" ]]; then
      name="$arg"
    fi
  done

  if [[ -n "$name" ]]; then
    _install_single_skill "$name" "$project"
    return
  fi

  # Interactive: pick from registry
  local names
  names=$(fetch_registry_skill_names) || return 1
  [[ -z "$names" ]] && { dim "No skills in registry."; return; }

  local opts=()
  while IFS= read -r n; do
    opts+=("$n")
  done <<< "$names"

  local selected
  selected=$(pick_many "Select skills to install:" "${opts[@]}") || return 0
  [[ -z "$selected" ]] && return 0

  while IFS= read -r n; do
    _install_single_skill "$n" "$project"
  done <<< "$selected"
}

cmd_skills_installed() {
  bold "Installed skills:"
  echo ""

  local found=0

  # Global skills
  local global_dir="${CLAUDE_CONFIG_DIR}/skills"
  if [[ -d "$global_dir" ]]; then
    for d in "$global_dir"/*/; do
      [[ -d "$d" ]] || continue
      [[ -f "${d}SKILL.md" ]] || continue
      found=1
      local name
      name=$(basename "$d")
      local desc
      desc=$(parse_frontmatter "description" < "${d}SKILL.md")
      if [[ -n "$desc" ]]; then
        printf "  %-24s %s  (global)\n" "$name" "$desc"
      else
        printf "  %-24s (global)\n" "$name"
      fi
    done
  fi

  # Project skills
  if [[ -d ".claude/skills" ]]; then
    for d in .claude/skills/*/; do
      [[ -d "$d" ]] || continue
      [[ -f "${d}SKILL.md" ]] || continue
      found=1
      local name
      name=$(basename "$d")
      local desc
      desc=$(parse_frontmatter "description" < "${d}SKILL.md")
      if [[ -n "$desc" ]]; then
        printf "  %-24s %s  (project)\n" "$name" "$desc"
      else
        printf "  %-24s (project)\n" "$name"
      fi
    done
  fi

  if [[ $found -eq 0 ]]; then
    dim "  No skills installed."
  fi
}

cmd_skills_remove() {
  local name="${1:-}"
  [[ -z "$name" ]] && die "Usage: ccm skills remove <name>"

  local removed=false

  # Try project first
  if [[ -d ".claude/skills/${name}" ]]; then
    rm -rf ".claude/skills/${name}"
    green "Removed skill '${name}' from project."
    removed=true
  fi

  # Try global
  local global_dir="${CLAUDE_CONFIG_DIR}/skills/${name}"
  if [[ -d "$global_dir" ]]; then
    rm -rf "$global_dir"
    green "Removed skill '${name}' from global."
    removed=true
  fi

  if [[ "$removed" == false ]]; then
    die "Skill '${name}' not found."
  fi
}

cmd_skills_update() {
  local name="${1:-}"

  if [[ -n "$name" ]]; then
    local global_dir="${CLAUDE_CONFIG_DIR}/skills/${name}"
    local project_dir=".claude/skills/${name}"

    local remote_skill
    remote_skill=$(gh_raw "${REGISTRY_BASE}/skills/${name}/SKILL.md") || die "Skill '${name}' not found in registry."
    local remote_hash
    remote_hash=$(echo "$remote_skill" | content_hash)

    if [[ -d "$project_dir" ]]; then
      local local_hash
      local_hash=$(echo "$(cat "${project_dir}/SKILL.md")" | content_hash)
      if [[ "$remote_hash" == "$local_hash" ]]; then
        dim "Skill '${name}' already up to date (project)."
      else
        rm -rf "$project_dir"
        _install_single_skill "$name" true
      fi
    fi

    if [[ -d "$global_dir" ]]; then
      local local_hash
      local_hash=$(echo "$(cat "${global_dir}/SKILL.md")" | content_hash)
      if [[ "$remote_hash" == "$local_hash" ]]; then
        dim "Skill '${name}' already up to date (global)."
      else
        rm -rf "$global_dir"
        _install_single_skill "$name"
      fi
    fi

    [[ ! -d "$project_dir" && ! -d "$global_dir" ]] && die "Skill '${name}' not installed."
    return
  fi

  # Update all installed skills
  local found=0

  local global_dir="${CLAUDE_CONFIG_DIR}/skills"
  if [[ -d "$global_dir" ]]; then
    for d in "$global_dir"/*/; do
      [[ -d "$d" ]] || continue
      [[ -f "${d}SKILL.md" ]] || continue
      found=1
      local n
      n=$(basename "$d")
      local remote_skill
      remote_skill=$(gh_raw "${REGISTRY_BASE}/skills/${n}/SKILL.md") || continue
      local remote_hash
      remote_hash=$(echo "$remote_skill" | content_hash)
      local local_hash
      local_hash=$(echo "$(cat "${d}SKILL.md")" | content_hash)
      if [[ "$remote_hash" == "$local_hash" ]]; then
        dim "Skill '${n}' already up to date (global)."
      else
        rm -rf "$d"
        _install_single_skill "$n" 2>/dev/null || true
      fi
    done
  fi

  if [[ -d ".claude/skills" ]]; then
    for d in .claude/skills/*/; do
      [[ -d "$d" ]] || continue
      [[ -f "${d}SKILL.md" ]] || continue
      found=1
      local n
      n=$(basename "$d")
      local remote_skill
      remote_skill=$(gh_raw "${REGISTRY_BASE}/skills/${n}/SKILL.md") || continue
      local remote_hash
      remote_hash=$(echo "$remote_skill" | content_hash)
      local local_hash
      local_hash=$(echo "$(cat "${d}SKILL.md")" | content_hash)
      if [[ "$remote_hash" == "$local_hash" ]]; then
        dim "Skill '${n}' already up to date (project)."
      else
        rm -rf "$d"
        _install_single_skill "$n" true 2>/dev/null || true
      fi
    done
  fi

  if [[ $found -eq 0 ]]; then
    dim "No skills to update."
  fi
}

# ─────────────────────────────────────────────
# PROFILE
# ─────────────────────────────────────────────
cmd_profile_pull() {
  local target="${CLAUDE_CONFIG_DIR}/CLAUDE.md"

  local content
  content=$(gh_raw "${REGISTRY_BASE}/profile/CLAUDE.md") || die "Failed to fetch profile from registry."

  mkdir -p "$CLAUDE_CONFIG_DIR"
  echo "$content" > "$target"
  green "Profile pulled to ${target}"
}

cmd_profile_show() {
  local target="${CLAUDE_CONFIG_DIR}/CLAUDE.md"

  if [[ -f "$target" ]]; then
    cat "$target"
  else
    dim "No profile installed. Run: ccm profile pull"
  fi
}

cmd_profile_remove() {
  local target="${CLAUDE_CONFIG_DIR}/CLAUDE.md"

  if [[ -f "$target" ]]; then
    rm "$target"
    green "Profile removed (${target})"
  else
    die "No profile installed."
  fi
}

# ─────────────────────────────────────────────
# INSTALL / UPDATE (top-level)
# ─────────────────────────────────────────────
cmd_profile_update() {
  local target="${CLAUDE_CONFIG_DIR}/CLAUDE.md"

  if [[ ! -f "$target" ]]; then
    dim "No profile installed. Skipping."
    return
  fi

  local content
  content=$(gh_raw "${REGISTRY_BASE}/profile/CLAUDE.md") || die "Failed to fetch profile from registry."

  local remote_hash
  remote_hash=$(echo "$content" | content_hash)
  local local_hash
  local_hash=$(echo "$(cat "$target")" | content_hash)

  if [[ "$remote_hash" == "$local_hash" ]]; then
    dim "Profile already up to date."
  else
    echo "$content" > "$target"
    green "Updated profile (${target})."
  fi
}

cmd_install() {
  local project=false
  [[ "${1:-}" == "-p" ]] && project=true

  bold "Installing all agents..."
  echo ""

  local agent_names
  agent_names=$(fetch_registry_agent_names) || true

  if [[ -n "$agent_names" ]]; then
    while IFS= read -r name; do
      _install_single_agent "$name" "$project"
    done <<< "$agent_names"
  else
    dim "  No agents in registry."
  fi

  echo ""
  bold "Installing all skills..."
  echo ""

  local skill_names
  skill_names=$(fetch_registry_skill_names) || true

  if [[ -n "$skill_names" ]]; then
    while IFS= read -r name; do
      _install_single_skill "$name" "$project"
    done <<< "$skill_names"
  else
    dim "  No skills in registry."
  fi

  echo ""
  bold "Pulling profile..."
  echo ""
  cmd_profile_pull
}

cmd_update() {
  bold "Updating agents..."
  echo ""
  cmd_agents_update
  echo ""
  bold "Updating skills..."
  echo ""
  cmd_skills_update
  echo ""
  bold "Updating profile..."
  echo ""
  cmd_profile_update
}

# ─────────────────────────────────────────────
# NOTIFICATIONS
# ─────────────────────────────────────────────
SETTINGS_FILE="${CLAUDE_CONFIG_DIR}/settings.json"
NTFY_HOOK_SCRIPT="${CLAUDE_CONFIG_DIR}/hooks/ccm-ntfy.sh"

_ntfy_extract_topic() {
  [[ -f "$NTFY_HOOK_SCRIPT" ]] || return 1
  grep '^NTFY_TOPIC=' "$NTFY_HOOK_SCRIPT" 2>/dev/null | head -1 | cut -d'"' -f2
}

_ntfy_write_script() {
  local topic="$1"
  mkdir -p "$(dirname "$NTFY_HOOK_SCRIPT")"
  cat > "$NTFY_HOOK_SCRIPT" << 'HOOKEOF'
#!/usr/bin/env bash
NTFY_TOPIC="__TOPIC__"

INPUT=$(cat)
TYPE=$(echo "$INPUT" | python3 -c "import json,sys; print(json.load(sys.stdin).get('notification_type',''))" 2>/dev/null)
MSG=$(echo "$INPUT" | python3 -c "import json,sys; print(json.load(sys.stdin).get('message',''))" 2>/dev/null)
CWD=$(echo "$INPUT" | python3 -c "import json,sys; print(json.load(sys.stdin).get('cwd',''))" 2>/dev/null)
PROJECT=$(basename "$CWD")

case "$TYPE" in
  idle_prompt)       TITLE="Claude idle — $PROJECT"; TAGS="white_check_mark"; PRIO="default" ;;
  permission_prompt) TITLE="Permission needed — $PROJECT"; TAGS="lock"; PRIO="high" ;;
  auth_success)      TITLE="Auth success — $PROJECT"; TAGS="key"; PRIO="low" ;;
  elicitation_dialog) TITLE="Input needed — $PROJECT"; TAGS="question"; PRIO="high" ;;
  *)                 TITLE="Claude — $PROJECT"; TAGS="bell"; PRIO="default" ;;
esac

curl -sf \
  -H "Title: $TITLE" \
  -H "Tags: $TAGS" \
  -H "Priority: $PRIO" \
  -d "$MSG" \
  "ntfy.sh/$NTFY_TOPIC" >/dev/null 2>&1

exit 0
HOOKEOF
  sed -i '' "s|__TOPIC__|${topic}|" "$NTFY_HOOK_SCRIPT"
  chmod +x "$NTFY_HOOK_SCRIPT"
}

cmd_notification_setup() {
  local default_topic="ccm-$(LC_ALL=C tr -dc 'a-f0-9' < /dev/urandom | head -c 8)"

  printf "Enter ntfy.sh topic [%s]: " "$default_topic"
  local topic
  read -r topic
  topic="${topic:-$default_topic}"

  # Write the hook script
  _ntfy_write_script "$topic"

  # Register hook in settings.json (no matcher = all notification types)
  mkdir -p "$CLAUDE_CONFIG_DIR"

  python3 -c "
import json, os

path = '$SETTINGS_FILE'
script = '$NTFY_HOOK_SCRIPT'

if os.path.exists(path):
    with open(path) as f:
        settings = json.load(f)
else:
    settings = {}

hook_entry = {
    'hooks': [{
        'type': 'command',
        'command': script
    }]
}

hooks = settings.setdefault('hooks', {})
notif_hooks = hooks.get('Notification', [])

# Remove any existing ccm-ntfy hook
notif_hooks = [h for h in notif_hooks if not
    any('ccm-ntfy.sh' in hk.get('command', '') for hk in h.get('hooks', []))]

notif_hooks.append(hook_entry)
hooks['Notification'] = notif_hooks

with open(path, 'w') as f:
    json.dump(settings, f, indent=2)
    f.write('\n')
" || die "Failed to write settings."

  green "Notifications enabled (topic: ${topic})"
  echo ""
  echo "  All notification types are active:"
  echo "    idle_prompt        — Claude finished, waiting for input"
  echo "    permission_prompt  — Claude needs permission to proceed"
  echo "    auth_success       — Authentication completed"
  echo "    elicitation_dialog — Claude is asking for input"
  echo ""
  dim "Subscribe at: https://ntfy.sh/${topic}"
}

cmd_notification_status() {
  local topic
  if topic=$(_ntfy_extract_topic) && [[ -n "$topic" ]]; then
    green "Notifications: enabled (topic: ${topic})"
    dim "Subscribe at: https://ntfy.sh/${topic}"
  else
    dim "Notifications: not configured"
    dim "Run: ccm notification setup"
  fi
}

cmd_notification_test() {
  local topic
  topic=$(_ntfy_extract_topic) || die "No notification hook configured. Run: ccm notification setup"
  [[ -z "$topic" ]] && die "No notification hook configured. Run: ccm notification setup"

  # Simulate each notification type
  local project
  project=$(basename "$PWD")

  curl -sf \
    -H "Title: Claude idle — ${project}" \
    -H "Tags: white_check_mark" \
    -d "Test: Claude is waiting for input" \
    "ntfy.sh/${topic}" >/dev/null \
    && green "Test notification sent to topic '${topic}'" \
    || die "Failed to send notification."
}

cmd_notification_remove() {
  [[ -f "$SETTINGS_FILE" ]] || die "No settings file found."

  local topic
  topic=$(_ntfy_extract_topic) || die "No notification hook configured."
  [[ -z "$topic" ]] && die "No notification hook configured."

  # Remove hook from settings.json
  python3 -c "
import json

path = '$SETTINGS_FILE'
with open(path) as f:
    settings = json.load(f)

hooks = settings.get('hooks', {})
notif_hooks = hooks.get('Notification', [])

notif_hooks = [h for h in notif_hooks if not
    any('ccm-ntfy.sh' in hk.get('command', '') for hk in h.get('hooks', []))]

if notif_hooks:
    hooks['Notification'] = notif_hooks
else:
    hooks.pop('Notification', None)

if not hooks:
    settings.pop('hooks', None)

with open(path, 'w') as f:
    json.dump(settings, f, indent=2)
    f.write('\n')
" || die "Failed to update settings."

  # Remove the hook script
  rm -f "$NTFY_HOOK_SCRIPT"

  green "Notification hook removed (was topic: ${topic})"
}

